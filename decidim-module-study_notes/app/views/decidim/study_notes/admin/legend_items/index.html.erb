<% add_decidim_page_title(t(".title")) %>
<%#= admin_tabs(:admin_study_notes_menu).render %>

<div class="card">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <%= t(".title") %>
      <%= link_to 'Uwagi do planu ogólnego', study_notes_path, class: "button button__sm button__secondary" %>
      <%= link_to "Dodaj pozycję legendy", new_legend_item_path, class: "button button__sm button__secondary" %>
    </h1>
  </div>

  <div class="card-section">
    <div class="table-scroll">
      <table class="table-list">
        <thead>
        <th>Nazwa</th>
        <th>Podkład mapowy</th>
        <th>Plik</th>
        <th>Data dodania</th>
        <th class="actions">Akcje</th>
        </thead>
        <tbody>
        <% @legend_items.each do |item| %>
          <tr data-id="<%= item.id %>">
            <td>
              <%= item.name %>
            </td>
            <td>
              <%= item.map_background.name  %>
            </td>
            <td>
              <%= link_to item.file.filename, main_app.url_for(item.file) if item.file.attached? %>
            </td>
            <td>
              <%= l item.created_at, format: "%d/%m/%Y - %H:%M" %>
            </td>
            <td class="table-list__actions">
              <%= icon_link_to "pencil-line", [:edit, item], t("actions.edit", scope: "decidim.admin"), class: "action-icon--edit", method: :get, data: {} %>
              <%= icon_link_to "delete-bin-line", legend_item_path(item), t("actions.destroy", scope: "decidim.admin"), class: "action-icon--remove", method: :delete, data: { confirm: t("actions.confirm_destroy", scope: "decidim.admin") } %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
      <%= paginate @legend_items, theme: "decidim" %>
    </div>
  </div>
</div>