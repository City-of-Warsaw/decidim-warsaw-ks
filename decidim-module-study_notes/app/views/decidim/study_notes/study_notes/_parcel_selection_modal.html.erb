<%= decidim_modal id: "parcelSelectionModal" do %>
  <div data-dialog-container>
    <%= icon "map-pin-line" %>
    <h3 class="h3"><%= t(".title") %> <span data-note-id></span></h3>

    <div>
      <p id="parcelSelectionModal-description" class="whitespace-pre-line leading-normal"></p>
    </div>
  </div>

  <div data-dialog-actions>
    <button type="button" class="button button__lg button__transparent-secondary" data-dialog-close="parcelSelectionModal" data-action="cancel-parcel-selection">
      <%= t(".cancel") %>
    </button>

    <button type="button" class="button button__lg button__primary" data-dialog-close="parcelSelectionModal" data-action="add-parcel-to-note">
      <%= t(".add") %>
    </button>
  </div>
<% end %>