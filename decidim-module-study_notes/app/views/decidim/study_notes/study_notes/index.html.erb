    function renderFunctionalProfileAreaInfo() {
      var detailedNotes = JSON.parse(
        $("#study_note_detailed_notes").val() ||
          `[{"index": "0", "name": "Plan ogólny gminy"}]`
      );

      detailedNotes.forEach(function (item) {
        const index = item.index;
        const value = item.functional_profile_area_id;
        const selectedClasses = item.functional_profile_area_classes || []; 

        let helpText = "";
        let checkboxesHtml = "";

        <% t("activemodel.attributes.study_note.functional_profile_areas_main_profile").each do |id, text| %>
          if(value == "<%= id %>") {
            $(`#study_note_detailed_notes_functional_profile_area_classes_${index}_wrapper`).removeClass("hidden");
            $(`#study_note_detailed_notes_functional_profile_area_classes_${index}_wrapper`).removeAttr("hidden");            

            helpText = `Profil podstawowy strefy <%= id %>: <%= j text %>`;

            const toggleCheckboxes = `<%= t("activemodel.attributes.study_note.functional_profile_area_classes." + id.to_s).split(",").each_with_index.map { |item, index| "study_note_detailed_notes_functional_profile_area_classes_${index}_#{index}" }.join(", ") %>`.replace(/\$\{index\}/g, index);

            checkboxesHtml = `
              <% t("activemodel.attributes.study_note.functional_profile_area_classes." + id.to_s).split(",").each_with_index do |class_name, class_id| %>
                <div>
                  <label for="study_note_detailed_notes_functional_profile_area_classes_${index}_<%= class_id %>">
                    <input type="checkbox" id="study_note_detailed_notes_functional_profile_area_classes_${index}_<%= class_id %>" name="study_note_detailed_notes_functional_profile_area_classes_${index}" data-index="${index}" data-key="functional_profile_area_classes" value="<%= class_name %>" data-mode="multiple" ${selectedClasses.includes("<%= class_name %>") && "checked"} ${selectedClasses.includes("nie chcę, aby strefa miała profil dodatkowy") && "disabled"} />
                    <%= class_name %>
                  </label>
                </div>
              <% end %>

              <div>
                <label for="study_note_detailed_notes_functional_profile_area_classes_${index}_null">
                  <input type="checkbox" id="study_note_detailed_notes_functional_profile_area_classes_${index}_null" name="study_note_detailed_notes_functional_profile_area_classes_${index}" required data-index="${index}" data-key="functional_profile_area_classes" value="nie chcę, aby strefa miała profil dodatkowy" data-toggle-input="${toggleCheckboxes}" data-mode="multiple" ${selectedClasses.includes("nie chcę, aby strefa miała profil dodatkowy") && "checked"} />
                  nie chcę, aby strefa miała profil dodatkowy
                </label>
              </div>
            `;
          }
        <% end %>

        $(
          `div.help-text[data-index='${index}'][data-key='functional_profile_area_id']`
        ).html(helpText);

        $(`#study_note_detailed_notes_functional_profile_area_classes_${index}`).html(checkboxesHtml);

        $(`#study_note_detailed_notes_functional_profile_area_classes_${index}`).find("input[type=checkbox]").each(function() {
          $(this).on("change", function(event) {
            var detailedNotes = JSON.parse(
              $("#study_note_detailed_notes").val() ||
                `[{"index": "0", "name": "Plan ogólny gminy"}]`
            );
            var index = parseInt($(this).data("index"));
            var key = $(this).data("key");
            var mode = $(this).data("mode");

            var value = event.target.value;  

            if(mode === "multiple") {
              var existingValues = detailedNotes[index][key] || [];
              
              if(value === "nie chcę, aby strefa miała profil dodatkowy") {
                if($(this).is(":checked")) {
                  existingValues = ["nie chcę, aby strefa miała profil dodatkowy"]; 
                } else {
                  existingValues = existingValues.filter(function(item) {
                    return item !== value;
                  });
                }
              } else {
                if($(this).is(":checked")) {
                  existingValues.push(value);
                } else {
                  existingValues = existingValues.filter(function(item) {
                    return item !== value;
                  });
                }
              } 

              detailedNotes[index][key] = [...new Set(existingValues)]; 
            } else {
              detailedNotes[index][key] = value;
            }

            $("#study_note_detailed_notes").val(
              JSON.stringify(detailedNotes)
            );
          });
        });
      });

      Foundation.reInit("abide");
    }


    function initDetailedNotesChangeEvents() {
      $(
        "#detailed_notes input, #detailed_notes textarea, #detailed_notes select"
      ).on("change", function (event) {
        var detailedNotes = JSON.parse(
          $("#study_note_detailed_notes").val() ||
            `[{"index": "0", "name": "Plan ogólny gminy"}]`
        );
        var index = parseInt($(this).data("index"));
        var key = $(this).data("key");
        var mode = $(this).data("mode");

        var value = event.target.value; 

        if(mode === "multiple") {
          var existingValues = detailedNotes[index][key] || [];
          
          if(value === "nie chcę, aby strefa miała profil dodatkowy") {
            if($(this).is(":checked")) {
              existingValues = ["nie chcę, aby strefa miała profil dodatkowy"]; 
            } else {
              existingValues = existingValues.filter(function(item) {
                return item !== value;
              });
            }
          } else {
            if($(this).is(":checked")) {
              existingValues.push(value);
            } else {
              existingValues = existingValues.filter(function(item) {
                return item !== value;
              });
            }
          } 

          detailedNotes[index][key] = [...new Set(existingValues)];
        } else {
          detailedNotes[index][key] = value;
        }

        if(key === "functional_profile_area_id") { 
          detailedNotes[index]["functional_profile_area_classes"] = [];
        }

        $("#study_note_detailed_notes").val(
          JSON.stringify(detailedNotes)
        );

        if (key === "functional_profile_area_id") {
          renderFunctionalProfileAreaInfo();
        }
      });

      $("#detailed_notes .multiple-hash-input__delete-button-js").off("click");
      $(
        "#detailed_notes .multiple-hash-input__delete-button-js"
      ).on("click", function () {
        var index = $(this).data("index");
        var detailedNotes = JSON.parse(
          $("#study_note_detailed_notes").val() ||
            `[{"index": "0", "name": "Plan ogólny gminy"}]`
        );
        detailedNotes = detailedNotes.filter(function (item) {
          return item.index != index;
        });

        detailedNotes = detailedNotes.map(function(item, newIndex) {
          return {
            ...item,
            index: newIndex
          };
        });

        $("#study_note_detailed_notes").val(
          JSON.stringify(detailedNotes)
        );

        renderDetailedNotes();
        initDetailedNotesChangeEvents();
      });

      $("#detailed_notes .multiple-hash-input__items > li").each(
        function () {
          const index = this.id.split("_").pop();
          const regex = new RegExp(
            `detailed_notes_(parcel_id|body|is_record_area_included)_item_${index}`
          );

          $("input:not([type=radio]), textarea")
            .filter(function () {
              return this.id.match(regex);
            })
            .on("change", function (event) {
              const inputs = $("input:not([type=radio]), textarea").filter(
                function () {
                  return this.id.match(regex);
                }
              );
              const radioInputs = $("input[type=radio]").filter(function () {
                return this.id.match(regex);
              });

              if (event.target.value.length > 0) {
                inputs.attr("required", "required");
                radioInputs.attr("required", "required");
                inputs.each(function () {
                  const label = $("label[for='" + this.id + "']");
                  label.find("span.asterisk").remove();
                  $(label).append('<span class="asterisk">*</span>');
                });
              } else {
                const emptyInputs = $("input:not([type=radio]), textarea").filter(
                  function () {
                    return this.id.match(regex) && this.value === "";
                  }
                );

                if (emptyInputs.length === inputs.length) {
                  inputs.removeAttr("required");
                  radioInputs.removeAttr("required");
                  inputs.each(function () {
                    $("#new_study_note_").foundation(
                      "validateInput",
                      $(this)
                    );

                    const label = $("label[for='" + this.id + "']");
                    label.find("span.asterisk").remove();
                  });
                }
              }
            });
        }
      );

      $("#detailed_notes").on("change", "input[type=radio]", function(event) { 
        const name = $(this).attr("name");
        const radioGroup = $(`input[type=radio][name="${name}"]`);

        if (name.includes("detailed_notes_functional_profile")) {
          renderFunctionalProfileAreaInfo();
        };
        
        radioGroup.filter("[data-toggle-target]").each(function() {
          const targetElement = $(`#${$(this).data("toggle-target")}`); 

          if ($(this).is(":checked")) {
            targetElement.removeClass("hidden"); 
            targetElement.removeAttr("hidden");

            targetElement.find("input, textarea, select").not("[type=file], [type=checkbox], [type=number]").each(function() { 
              $(this).removeAttr("disabled"); 
              $(this).attr("required", "required");

              if($(this).is("[type=radio]")) return;
              
              const label = $("label[for='" + this.id + "']"); 

              label.find("span.asterisk").remove();
              label.append('<span class="asterisk">*</span>');
            }); 

            targetElement.find("input[type=checkbox], input[type=number], input[type=radio]").each(function() {
              $(this).removeAttr("data-abide-ignore")
            });
          } else {
            targetElement.addClass("hidden");
            targetElement.attr("hidden", "");
            
            targetElement.find("input, textarea, select").not("[type=file], [type=checkbox], [type=number]").each(function() {
              $(this).attr("disabled", ""); 
              $(this).removeAttr("required"); 

              if($(this).is("[type=radio]")) return;

              const label = $("label[for='" + this.id + "']"); 
            
              label.find("span.asterisk").remove();

              $("#new_study_note_").foundation("removeErrorClasses", $(this));
            }); 

            targetElement.find("input[type=checkbox], input[type=number], input[type=radio]").each(function() {
              $(this).attr("data-abide-ignore", "");
              $('#new_study_note_').foundation('removeErrorClasses', $(this));
            });
          }
        });
      });

      $("#detailed_notes").on("change", "input[type=checkbox][data-toggle-input]", function(event) { 
        if ($(this).data("toggle-input").includes(",")) {
          const targetIds = $(this).data("toggle-input").split(",");

          targetIds.forEach(function(targetId) {
            const targetElement = $(`#${targetId.trim()}`); 

            if ($(this).is(":checked")) { 
              targetElement.attr("disabled", ""); 
              targetElement.prop("checked", false); 
            } else { 
              targetElement.removeAttr("disabled"); 
            } 
          }.bind(this));
        } else {
          const targetElement = $(`#${$(this).data("toggle-input")}`); 
          const label = $("label[for='" + targetElement.attr("id") + "']");

          if ($(this).is(":checked")) { 
            targetElement.removeAttr("disabled");
            targetElement.attr("required", "required");

            label.find("span.asterisk").remove();
            label.append('<span class="asterisk">*</span>');
          } else { 
            targetElement.attr("disabled", "");
            targetElement.removeAttr("required");

            label.find("span.asterisk").remove();

            $("#new_study_note_").foundation("removeErrorClasses", targetElement);
          }
        }
      });

      $("#detailed_notes").on("change", "select[data-toggle-input]", function(event) { 
        const targetElement = $(`#${$(this).data("toggle-input")}`); 

        if ($(this).val().length > 0) { 
          targetElement.removeClass("hidden");
          targetElement.removeAttr("hidden");
        } else { 
          targetElement.addClass("hidden");
          targetElement.attr("hidden", "");
        } 
      });
      
      $("#detailed_notes input[type=file]")
        .not(".MultiFile-applied")
        .MultiFile({
          max: 1,
          STRING: {
            remove: "usuń",
            denied: "Ten format pliku $ext jest niedozwolony.",
            file: "$file",
            selected: "Wybrany plik: $file",
            duplicate: "Ten plik już został wybrany:\n$file",
            toomuch: "Łączny rozmiar plików przekracza limit ($size)",
            toomany: "Niedozwolona liczba plików (maks: $max)",
            toobig: "$file ma za duży rozmiar (maks: $size)",
          },
          afterFileAppend: function (element, value, master_element) {
            if (master_element.files.length >= 1) {
              $(this).parent().find(".attachment-button-js").hide();
              $(this).parent().find("[id^=detailed_notes_is_parcel_site_boundary_included]").val(true);
              $(this).parent().find("[id^=detailed_notes_is_parcel_site_boundary_included]").trigger("change");
            }
          },
          afterFileRemove: function (element, value, master_element) {
            if (master_element.files.length < 1) {
              $(this).parent().find(".attachment-button-js").show();
              $(this).parent().find("[id^=detailed_notes_is_parcel_site_boundary_included]").val(false);
              $(this).parent().find("[id^=detailed_notes_is_parcel_site_boundary_included]").trigger("change");
            }
          },
        });

      $(".show-map-modal-js").click(function(e) {
        e.preventDefault();
        const id = $(this).data("detailed-note-id");
        
        if(id !== window.Decidim.currentDetailedNoteId){
          window.Decidim.currentDetailedNoteId = id;

          if (window.Decidim.studyNoteMap){
            window.Decidim.studyNoteMapRefreshParcelsLayer(window.Decidim.studyNoteMap);
          }
        }
        
        window.Decidim.currentDialogs.mapModal.open(e.currentTarget);
      });

      
      $(".attachment-button-js")
        .not(".AttachmentButton-applied")
        .each(function () {
          $(this).addClass("AttachmentButton-applied");
        })
        .click(function (e) {
          e.preventDefault(); 

          var target_id = $(this).data("target");
          $(this)
            .closest("div")
            .find(target_id + " > input")
            .last()
            .click();
        });
    }

    $("#detailed_notes .multiple-hash-input__add-button-js").on(
      "click",
      function () {
        var detailedNotes = JSON.parse(
          $("#study_note_detailed_notes").val() ||
