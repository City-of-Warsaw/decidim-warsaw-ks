            $(this).parent().find(".attachment-button-js").show();
          }
        },
      });

    $("input[type=file]#study_note_files")
      .not(".MultiFile-applied")
      .MultiFile({
        max: 2,
        STRING: {
          remove: "usuń",
          denied: "Ten format pliku $ext jest niedozwolony.",
          file: "$file",
          selected: "Wybrany plik: $file",
          duplicate: "Ten plik już został wybrany:\n$file",
          toomuch: "Łączny rozmiar plików przekracza limit ($size)",
          toomany: "Niedozwolona liczba plików (maks: $max)",
          toobig: "$file ma za duży rozmiar (maks: $size)",
        },
        afterFileAppend: function (element, value, master_element) {
          master_element.files.forEach(function (file, index) {
            if (index === 0 && master_element.files.length > 1) {
              if (
                $(`#study_note_files_list > div:eq(${index})`).hasClass(
                  "MultiFile-label--added-inputs"
                )
              ) {
                return;
              } else {
                $(`#study_note_files_list > div:eq(${index})`).append(
                  `
                    <div>
                      <label for="files_filename_one" ><%= t('activemodel.attributes.study_note.files_filename_one') %> 1</label>
                      <input id="files_filename_one" type="text" name="study_note[files_filename_one]" required /> 
                      <span class="form-error"><%= t("errors.messages.required") %></span>
                    </div>
                    <div>
                      <label for="files_filename_two" ><%= t('activemodel.attributes.study_note.files_filename_two') %> 2</label>
                      <input id="files_filename_two" type="text" name="study_note[files_filename_two]" required /> 
                      <span class="form-error"><%= t("errors.messages.required") %></span>
                    </div>
                  `
                );
                $(`#study_note_files_list > div:eq(${index})`).addClass(
                  "MultiFile-label--added-inputs"
                );
              }
            }

            if (
              !$(`#study_note_files_list > div:eq(${index})`).hasClass(
                "MultiFile-label--added-inputs"
              )
            ) {
              $(`#study_note_files_list > div:eq(${index})`).append(
                `
                  <div>
                    <label for="files_filename_${
                      index === 0 ? "one" : "two"
                    }" ><%= t('activemodel.attributes.study_note.files_filename_one') %></label>
                    <input id="files_filename_${
                      index === 0 ? "one" : "two"
                    }" type="text" name="study_note[files_filename_${
                  index === 0 ? "one" : "two"
                }]" required /> 
                    <span class="form-error"><%= t("errors.messages.required") %></span>
                  </div>
                `
              );

              $(`#study_note_files_list > div:eq(${index})`).addClass(
                "MultiFile-label--added-inputs"
              );
            }

            Foundation.reInit("abide");
          });

          if (master_element.files.length >= 2) {
            $(this).parent().find(".attachment-button-js").hide();
          }
        },
        afterFileRemove: function (element, value, master_element) {
          if (master_element.files.length < 2) {
            $(this).parent().find(".attachment-button-js").show();
          }
        },
      });

      $(document).ready(function () {
        renderDetailedNotes();
        initDetailedNotesChangeEvents();
      });
  <% end %>
<% end %>