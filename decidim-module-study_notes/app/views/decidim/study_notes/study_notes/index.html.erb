                        }" data-key="inner_city_development_include" ${
                          item.inner_city_development_include === "false" && "checked"
                        }>
                        <label for="detailed_notes_inner_city_development_include_item_${
                          item.index
                        }_false"><%= t("activemodel.attributes.study_note.detailed_notes_inner_city_development_exclude") %></label>
                      </div> 
                    </div>
                  </div>

                  <div> 
                    <label for="detailed_notes_social_infrastructure_accessibility_item_${
                      item.index
                    }"><%= t('activemodel.attributes.study_note.detailed_notes_social_infrastructure_accessibility') %></label> 

                    <div class="radio-wrapper">
                      <input type="radio" value="true" name="detailed_notes_social_infrastructure_accessibility_item_${
                        item.index
                      }" id="detailed_notes_social_infrastructure_accessibility_item_${
                        item.index
                      }_true" data-index="${item.index}" data-key="detailed_notes_social_infrastructure_accessibility" ${
                        item.detailed_notes_social_infrastructure_accessibility === "true" && "checked"
                      } data-toggle="detailed_notes_social_infrastructure_accessibility_details_item_${
                        item.index
                      }">
                      <label for="detailed_notes_social_infrastructure_accessibility_item_${
                        item.index
                      }_true"><%= t(".option_yes") %></label>

                      <input type="radio" value="false" name="detailed_notes_social_infrastructure_accessibility_item_${
                        item.index
                      }" id="detailed_notes_social_infrastructure_accessibility_item_${
                        item.index
                      }_false" data-index="${
                        item.index
                      }" data-key="detailed_notes_social_infrastructure_accessibility" ${
                        item.detailed_notes_social_infrastructure_accessibility === "false" && "checked"
                      }>
                      <label for="detailed_notes_social_infrastructure_accessibility_item_${
                        item.index
                      }_false"><%= t(".option_no") %></label>
                    </div>
                  </div>
                  
                  <div id="detailed_notes_social_infrastructure_accessibility_details_item_${
                    item.index
                  }" data-toggler=".hidden" class="field file-field relative hidden p-4 border-white border-4">
                    <div>
                      <label for="detailed_notes_social_infrastructure_accessibility_body_item_${
                        item.index
                      }" ><%= t('activemodel.attributes.study_note.detailed_notes_social_infrastructure_accessibility_body') %></label>
                      <textarea maxlength="1000" id="detailed_notes_social_infrastructure_accessibility_body_item_${
                        item.index
                      }" rows="8" data-remaining-characters="#detailed_notes_social_infrastructure_accessibility_body_item_${
                        item.index
                      }-characters" aria-describedby="detailed_notes_social_infrastructure_accessibility_body_item_${
                        item.index
                      }-characters" data-index="${item.index}" data-key="social_infrastructure_accessibility_body">${
                        item.social_infrastructure_accessibility_body || ""
                      }</textarea>
                      <span class="form-error"><%= t("errors.messages.required") %></span>
                    </div>
                  </div>

                  <button type="button" class="multiple-hash-input__delete-button multiple-hash-input__delete-button-js" data-index="${
                    item.index
                  }">
                    <%= image_pack_tag("media/images/trash.svg", alt: "") %>

                    <span>
                      <%= t(".delete_item") %>
                    </span>
                  </button>
                </div>
              </li>              
            `
        );
      });

      detailedNotes.slice(append ? -1 : undefined).forEach(function (item) {
        $("#selected_detailed_note_id").append(
          `<option value="${item.index}"><%= t(".area") %> ${parseInt(item.index + 1)}</option>`
        );
      });

      if (append) {
        $(
          "#detailed_notes .multiple-hash-input__items > li:last-of-type"
        ).foundation();
        $(
          "#detailed_notes .multiple-hash-input__items > li:last-of-type textarea"
        ).data(
          "remaining-characters-counter",
          new Decidim.InputCharacterCounter(
            $(
              "#detailed_notes .multiple-hash-input__items > li:last-of-type textarea"
            )
          )
        );        

        $(".attachment-button-js")
          .not(".AttachmentButton-applied")
          .click(function (e) {
            e.preventDefault();

            $(this).addClass("AttachmentButton-applied");

            var target_id = $(this).data("target");
            $(this)
              .closest("div")
              .find(target_id + " > input")
              .last()
              .click();
          });
      } else {
        $(
          "#detailed_notes .multiple-hash-input__items"
        ).foundation(); 
      }

      Foundation.reInit("abide");
    }

    renderDetailedNotes();
    initDetailedNotesChangeEvents();

    function initDetailedNotesChangeEvents() {
      $(
        "#detailed_notes input, #detailed_notes textarea, #detailed_notes select"
      ).on("change", function (event) {
        var detailedNotes = JSON.parse(
          $("#study_note_detailed_notes").val() ||
            `[{"index": "0", "name": "Plan ogólny gminy"}]`
        );
        var index = parseInt($(this).data("index"));
        var key = $(this).data("key");
        var value = event.target.value;

        detailedNotes[index][key] = value;
        $("#study_note_detailed_notes").val(
          JSON.stringify(detailedNotes)
        );
      });

      $(
        "#detailed_notes .multiple-hash-input__delete-button-js"
      ).on("click", function () {
        var index = $(this).data("index");
        var detailedNotes = JSON.parse(
          $("#study_note_detailed_notes").val() ||
            `[{"index": "0", "name": "Plan ogólny gminy"}]`
        );
        detailedNotes = detailedNotes.filter(function (item) {
          return item.index != index;
        });
        $("#study_note_detailed_notes").val(
          JSON.stringify(detailedNotes)
        );

        renderDetailedNotes();
        initDetailedNotesChangeEvents();
      });

      $("#detailed_notes .multiple-hash-input__items > li").each(
        function () {
          const index = this.id.split("_").pop();
          const regex = new RegExp(
            `detailed_notes_(parcel_id|body|is_record_area_included)_item_${index}`
          );

          $("input:not([type=radio]), textarea")
            .filter(function () {
              return this.id.match(regex);
            })
            .on("change", function (event) {
              const inputs = $("input:not([type=radio]), textarea").filter(
                function () {
                  return this.id.match(regex);
                }
              );
              const radioInputs = $("input[type=radio]").filter(function () {
                return this.id.match(regex);
              });

              if (event.target.value.length > 0) {
                inputs.attr("required", "required");
                radioInputs.attr("required", "required");
                inputs.each(function () {
                  const label = $("label[for='" + this.id + "']");
                  label.find("span.asterisk").remove();
                  $(label).append('<span class="asterisk">*</span>');
                });
              } else {
                const emptyInputs = $("input:not([type=radio]), textarea").filter(
                  function () {
                    return this.id.match(regex) && this.value === "";
                  }
                );

                if (emptyInputs.length === inputs.length) {
                  inputs.removeAttr("required");
                  radioInputs.removeAttr("required");
                  inputs.each(function () {
                    $("#new_study_note_").foundation(
                      "validateInput",
                      $(this)
                    );

                    const label = $("label[for='" + this.id + "']");
                    label.find("span.asterisk").remove();
                  });
                }
              }
            });
        }
      );

      $("#detailed_notes").on("change", "input[type=radio]", function(event) { 
        const name = $(this).attr("name");
        const radioGroup = $(`input[type=radio][name="${name}"]`);
        
        radioGroup.filter("[data-toggle]").each(function() {
          const targetElement = $(`#${$(this).data("toggle")}`); 

          if ($(this).is(":checked")) {
            targetElement.removeClass("hidden");
            targetElement.removeAttr("hidden");
          } else {
            targetElement.addClass("hidden");
            targetElement.attr("hidden", "");
          }
        });
      });

      $("#detailed_notes").on("change", "input[type=checkbox][data-toggle-input]", function(event) { 
        const targetElement = $(`#${$(this).data("toggle-input")}`); 

        if ($(this).is(":checked")) { 
          targetElement.removeAttr("disabled");
        } else { 
          targetElement.attr("disabled", "");
        } 
      });
      
      $("#detailed_notes input[type=file]")
        .not(".MultiFile-applied")
        .MultiFile({
          max: 1,
          STRING: {
            remove: "usuń",
            denied: "Ten format pliku $ext jest niedozwolony.",
            file: "$file",
            selected: "Wybrany plik: $file",
            duplicate: "Ten plik już został wybrany:\n$file",
            toomuch: "Łączny rozmiar plików przekracza limit ($size)",
            toomany: "Niedozwolona liczba plików (maks: $max)",
            toobig: "$file ma za duży rozmiar (maks: $size)",
          },
          afterFileAppend: function (element, value, master_element) {
            if (master_element.files.length >= 1) {
              $(this).parent().find(".attachment-button-js").hide();
            }
          },
          afterFileRemove: function (element, value, master_element) {
            if (master_element.files.length < 1) {
              $(this).parent().find(".attachment-button-js").show();
            }
          },
        });

        $(".show-map-modal-js").click(function(e) {
          e.preventDefault();
          const id = $(this).data("detailed-note-id");
          
          if(id !== window.Decidim.currentDetailedNoteId){
            window.Decidim.currentDetailedNoteId = id;

            if (window.Decidim.studyNoteMap){
              window.Decidim.studyNoteMapRefreshParcelsLayer(window.Decidim.studyNoteMap);
            }
          }
          
          window.Decidim.currentDialogs.mapModal.open();
        });
    }

    $("#detailed_notes .multiple-hash-input__add-button-js").on(
      "click",
      function () {
        var detailedNotes = JSON.parse(
          $("#study_note_detailed_notes").val() ||
            `[{"index": "0", "name": "Plan ogólny gminy"}]`
        );
        detailedNotes.push({
          index: detailedNotes.length,
        });
        $("#study_note_detailed_notes").val(
          JSON.stringify(detailedNotes)
        );

        renderDetailedNotes(true);
        initDetailedNotesChangeEvents();
      }
    );

    $("input[type=file]#study_note_attorney_power_payment_stamp_duty_confirm, input[type=file]#study_note_attorney_power_represent_applicant_or_for_service")
      .not(".MultiFile-applied")
      .MultiFile({
        max: 1,
        STRING: {
          remove: "usuń",
          denied: "Ten format pliku $ext jest niedozwolony.",
          file: "$file",
          selected: "Wybrany plik: $file",
          duplicate: "Ten plik już został wybrany:\n$file",
          toomuch: "Łączny rozmiar plików przekracza limit ($size)",
          toomany: "Niedozwolona liczba plików (maks: $max)",
          toobig: "$file ma za duży rozmiar (maks: $size)",
        },
        afterFileAppend: function (element, value, master_element) {
          if (master_element.files.length >= 1) {
            $(this).parent().find(".attachment-button-js").hide();
          }
        },
        afterFileRemove: function (element, value, master_element) {
          if (master_element.files.length < 1) {
            $(this).parent().find(".attachment-button-js").show();
          }
        },
      });

    $("input[type=file]#study_note_files")
      .not(".MultiFile-applied")
      .MultiFile({
        max: 2,
        STRING: {
          remove: "usuń",
          denied: "Ten format pliku $ext jest niedozwolony.",
          file: "$file",
          selected: "Wybrany plik: $file",
          duplicate: "Ten plik już został wybrany:\n$file",
          toomuch: "Łączny rozmiar plików przekracza limit ($size)",
          toomany: "Niedozwolona liczba plików (maks: $max)",
          toobig: "$file ma za duży rozmiar (maks: $size)",
        },
        afterFileAppend: function (element, value, master_element) {
          master_element.files.forEach(function (file, index) {
            if (index === 0 && master_element.files.length > 1) {
              if (
                $(`#study_note_files_list > div:eq(${index})`).hasClass(
                  "MultiFile-label--added-inputs"
                )
              ) {
                return;
              } else {
                $(`#study_note_files_list > div:eq(${index})`).append(
                  `
                    <div>
                      <label for="files_filename_one" ><%= t('activemodel.attributes.study_note.files_filename_one') %> 1</label>
                      <input id="files_filename_one" type="text" name="study_note[files_filename_one]" required /> 
                      <span class="form-error"><%= t("errors.messages.required") %></span>
                    </div>
                    <div>
                      <label for="files_filename_two" ><%= t('activemodel.attributes.study_note.files_filename_two') %> 2</label>
                      <input id="files_filename_two" type="text" name="study_note[files_filename_two]" required /> 
                      <span class="form-error"><%= t("errors.messages.required") %></span>
                    </div>
                  `
                );
                $(`#study_note_files_list > div:eq(${index})`).addClass(
                  "MultiFile-label--added-inputs"
                );
              }
            }

            if (
              !$(`#study_note_files_list > div:eq(${index})`).hasClass(
                "MultiFile-label--added-inputs"
              )
            ) {
              $(`#study_note_files_list > div:eq(${index})`).append(
                `
                  <div>
                    <label for="files_filename_${
                      index === 0 ? "one" : "two"
                    }" ><%= t('activemodel.attributes.study_note.files_filename_one') %></label>
                    <input id="files_filename_${
                      index === 0 ? "one" : "two"
                    }" type="text" name="study_note[files_filename_${
                  index === 0 ? "one" : "two"
                }]" required /> 
                    <span class="form-error"><%= t("errors.messages.required") %></span>
                  </div>
                `
              );

              $(`#study_note_files_list > div:eq(${index})`).addClass(
                "MultiFile-label--added-inputs"
              );
            }

            Foundation.reInit("abide");
          });

          if (master_element.files.length >= 2) {
            $(this).parent().find(".attachment-button-js").hide();
          }
        },
        afterFileRemove: function (element, value, master_element) {
          if (master_element.files.length < 2) {
            $(this).parent().find(".attachment-button-js").show();
          }
        },
      });
  <% end %>
<% end %>