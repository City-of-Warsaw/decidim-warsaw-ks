<%= decidim_modal id: "mapGuideModal" do %>
  <div data-dialog-container>
    <%= icon "information-line" %>
    <h3 class="h3"><%= t(".title") %></h3>
 
    <div class="editor-content fix-swipebox"> 
      <%= map_guide %> 
    </div> 
  </div>

  <div data-dialog-actions>
    <button type="button" class="button button__lg button__primary" data-dialog-close="mapGuideModal">
      <%= t(".ok") %>
    </button>
  </div>
<% end %>

