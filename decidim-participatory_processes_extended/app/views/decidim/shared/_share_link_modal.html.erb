<%= decidim_modal id: modal_id, class: "share-modal" do %>
<div data-dialog-container>
  <%= icon "share-line" %>
  <h2 id="dialog-title-<%= modal_id %>" tabindex="-1" data-dialog-title><%= modal_title %></h2>
  <div>
    <div class="share-modal__input flex gap-2 items-center">
      <input id="urlShareLink-<%= modal_id %>" type="text" title="<%= t("share_link", scope: "decidim.shared.share_modal") %>" value="<%= share_url %>" readonly class="w-full !pr-[35%] sm:!pr-[25%] md:!pr-[15%] truncate">
      <button type="button"
        class="button button__sm button__text-secondary"
        data-clipboard-copy="#urlShareLink-<%= modal_id %>"
        data-clipboard-copy-label="<%= t("copy_share_link_copied", scope: "decidim.shared.share_modal") %>"
        data-clipboard-copy-message="<%= t("copy_share_link_message", scope: "decidim.shared.share_modal") %>"
        title="<%= t("copy_share_link_clarification", scope: "decidim.shared.share_modal") %>">
        <span><%= t("copy_share_link", scope: "decidim.shared.share_modal") %></span>
        <%= icon "file-copy-line" %>
      </button>
    </div>
  </div>
</div>
<% end %>
