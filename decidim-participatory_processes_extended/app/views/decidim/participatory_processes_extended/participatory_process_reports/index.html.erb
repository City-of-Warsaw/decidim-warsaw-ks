<% add_decidim_page_title(t("participatory_processes_extended.participatory_process_reports.index.title", scope: "decidim")) %>
<div class="results process-report-container">
  <div class="row column">
    <div class="row">
      <div class="columns mediumlarge-12">
        <div class="section">
            <div class="card--user_question">
              <div class="card__content">
                <div class="effects__title flex justify-between items-center">
                  <h3 class="title-decorator inline-block text-left mb-12">Raport z konsultacji</h3>

                  <% if current_participatory_space.report_publication_date.present? %>
                    <span><%= l(current_participatory_space.report_publication_date, format: :decidim_short_cut_zero) %></span>
                  <% end %>
                </div>

                <% if current_participatory_space.report_description.present? %>
                  <div class="editor-content mb-8">
                    <%= quill_sanitize(current_participatory_space.report_description) %>
                  </div>
                <% end %>

                <% if current_participatory_space.participatory_process_report_files.published.any? %> 
                  <% current_participatory_space.participatory_process_report_files.published.sorted_by_weight.each do |file| %>
                    <div class="single-file single-file--report">
                      <div class="single-file__text single-file__text--report">
                        <div>
                          <a href="<%= Rails.application.routes.url_helpers.rails_blob_path(file.file, only_path: true) %>" class="card__link" data-external-link="text-only" target="_blank">
                            <h4 class="single-file__heading single-file__heading--report">
                              <%= file.name %>
                            </h4>
                          </a>

                          <small class="block">
                            <%= file.file.filename.extension_without_delimiter.upcase %>,
                            <%= '%.2f' % ((file.file.byte_size / 1024000.0).ceil(2)) %> MB
                          </small>
                        </div>
                      </div>
                      <div class="single-file__data flex items-center gap-8">
                        <div class="flex justify-center tooltip-wrapper">
                          <%= render layout: 'decidim/shared/tooltip', locals: { tooltip_content: t("decidim.components.component.share_report") } do %>
                            <button type="button" class="card--list__data__icon" data-dialog-open="shareReportModal-<%= file.id %>" aria-label="<%= t("decidim.components.component.share_report") %>">
                              <%= icon "share-line", class: "w-8 h-6 text-primary fill-current", role: "img", "aria-hidden": true %>
                            </button>
                          <% end %>
                        </div>

                        <div class="flex justify-center tooltip-wrapper">
                          <%= render layout: 'decidim/shared/tooltip', locals: { tooltip_content: t("decidim.components.component.download_file") } do %>
                            <%= link_to Rails.application.routes.url_helpers.rails_blob_path(file.file, only_path: true), target: "_blank", rel: "noopener", class: "card--list__data__icon", data: { "external-link": "false" }, "aria-label": t("decidim.components.component.download_file") do %>
                              <%= icon "download-2-line" %>
                            <% end %>
                          <% end %>
                        </div>
                      </div>
                    </div>

                    <%= render "decidim/shared/share_link_modal", modal_id: "shareReportModal-#{file.id}", modal_title: t("decidim.components.component.share_report"), share_url: Rails.application.routes.url_helpers.rails_blob_url(file.file, host: current_organization.host) %>
                  <% end %> 
                <% end %>
              </div>
            </div>
        </div>
      </div>
    </div>
  </div>
</div>
