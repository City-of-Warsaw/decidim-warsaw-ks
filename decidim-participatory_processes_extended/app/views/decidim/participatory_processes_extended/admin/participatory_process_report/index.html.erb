<% add_decidim_page_title(t("participatory_processes", scope: "decidim.admin.titles")) %>

<div class="card with-overflow" id="processes">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      Raport
      <% if current_participatory_space.report_description.blank? %>
        <%= link_to t("index.new", scope: "decidim.participatory_processes_extended.admin.participatory_process_report"),
                    participatory_processes_reports_new_path,
                    class: "button button__sm button__secondary" %>
      <% end %>
      <% if current_participatory_space.report_description.present? &&
        current_participatory_space.consultation_status == 'report' && !current_participatory_space.report_notification_send %>
        <%= link_to t("index.send_notification", scope: "decidim.participatory_processes_extended.admin.participatory_process_report"),
                    participatory_processes_reports_send_notification_path, method: :post, data: { confirm: t("index.confirm_send", scope: "decidim.participatory_processes_extended.admin.participatory_process_report")},
            class: "button button__sm button__secondary" %>
      <% end %>
      <% if current_participatory_space.report_description.present? %>
        <%= link_to t("index.new_file", scope: "decidim.participatory_processes_extended.admin.participatory_process_report"),
                    participatory_processes_reports_list_new_file_path,
                    class: "button button__sm button__secondary" %>
      <% end %>
    </h1>
  </div>

  <div class="table-scroll">
    <table class="table-list">
      <thead>
      <tr>
        <th>
          Opis raportu
        </th>
        <th>
          Data wysyłki powiadomienia
        </th>
        <th>
          Publiczny
        </th>
        <th></th>
      </tr>
      </thead>
      <tbody>
      <% if current_participatory_space.report_description.present? || current_participatory_space.participatory_process_report_files.any? %>
        <tr>
          <td><%= truncate(strip_tags(current_participatory_space.report_description), { length: 100, delimiter: "..." }) %></td>
          <td>
            <% if current_participatory_space.report_notification_send_date.present? %>
              <span><%= l(current_participatory_space.report_notification_send_date, format: :decidim_short_cut_zero) %></span>
            <% else %>
              -
            <% end %>
          </td>
          <td>
            <% if current_participatory_space.report_published? %>
              <span>TAK</span>
            <% else %>
              NIE
            <% end %>
          </td>
          <td class="table-list__actions">
            <% if current_participatory_space.report_published? %>
              <%= icon_link_to "close-line", participatory_processes_reports_list_unpublish_path(current_participatory_space), t(".unpublish"), method: :post, class: "action-icon--unpublish icon" %>
            <% else %>
              <%= icon_link_to "check-line", participatory_processes_reports_list_publish_path(current_participatory_space), t(".publish"), method: :post, class: "action-icon--publish icon" %>
            <% end %>
            <%= icon_link_to "pencil-line", participatory_processes_reports_list_edit_path(current_participatory_space), t(".edit"), class: "action-icon--edit icon" %>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>


  <% if current_participatory_space.report_description.present? || current_participatory_space.participatory_process_report_files.any? %>
    <div class="card-divider">
      <div class="item_show__header">
        <h2 class="card-title">
          Pliki
        </h2>
      </div>
    </div>
    <div class="card-section">
      <div class="table-scroll">
        <table class="table-list">
          <thead>
          <tr>
            <th>Nazwa pliku</th>
            <th>Data dodania</th>
            <th>Publiczny</th>
            <th>Kolejność</th>
            <th></th>
          </tr>
          </thead>
          <tbody>
          <% current_participatory_space.participatory_process_report_files.sorted_by_weight.each do |file| %>
            <tr>
              <td><%= link_to file.name, Rails.application.routes.url_helpers.rails_blob_path(file.file, only_path: true), target: '_blank' %></td>
              <td><%= l(file.created_at, format: :decidim_short_cut_zero) %></td>
              <td><%= file.published ? "TAK" : "NIE" %></td>
              <td><%= file.weight %></td>
              <td class="table-list__actions">
                <%= icon_link_to "pencil-line", participatory_processes_reports_list_edit_file_path(current_participatory_space, file.id), t("actions.edit", scope: "decidim.admin"), class: "action-icon--edit icon", method: :get %>
                <%= icon_link_to "delete-bin-line", participatory_processes_reports_list_delete_file_path(current_participatory_space, file.id), t("actions.destroy", scope: "decidim.admin"), class: "action-icon--remove icon", method: :delete, data: { confirm: t("actions.confirm_destroy", scope: "decidim.admin") } %>
              </td>
            </tr>
          <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
