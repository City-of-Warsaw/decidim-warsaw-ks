<div class="form__wrapper">
  <div class="card pt-4">
    <div class="card-section">
      <div class="row">
        <div class="row column">
          <%= form.text_field :name %>
        </div>

        <div class="row column">
          <%= form.number_field :weight %>
        </div>

        <div class="row column">
          <%= form.label :published %>
          <%= form.radio_button :published, false, label: t(".published_no") %>
          <%= form.radio_button :published, true, label: t(".published_yes") %>
        </div>

        <div class="columns xlarge-6">
          <%#= form.upload :file, button_class: "button button__sm button__transparent-secondary" %>

          <%= form.file_field :file,
                              label: @form.persisted? ? "Zamień plik" : "Dodaj plik",
                              multiple: false,
                              accept: ".pdf,.doc,.docx,.jpg,.jpeg,.gif,.png,.bmp"
          %>
          <% if @form.persisted? %>
            <p>Bieżący plik: <%= link_to @form.name,
                                         Rails.application.routes.url_helpers.rails_blob_path(@form.file, only_path: true),
                                         target: '_blank' %></p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>