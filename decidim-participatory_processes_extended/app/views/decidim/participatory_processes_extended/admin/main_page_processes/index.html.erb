<% add_decidim_page_title(t("main_page_process", scope: "decidim.admin.titles")) %>

<% content_for :breadcrumb_context_menu, flush: true do %>
  <div class="process-title-content-breadcrumb-container-right">
    <%= link_to [:new, :main_page_process], class: "button button__sm button__transparent process-title-content-breadcrumb-container-right-link" do %>
      <%= icon "add-line" %>
      <span>
        <%= t(".new") %>
      </span>
    <% end %>
    <%#= render partial: "layouts/decidim/admin/manage_processes" %>
  </div>
<% end %>

<%= admin_tabs(:admin_participatory_processes_menu).render %>
<div class="card" id="processes">
  <div class="card-divider">
    <h2 class="card-title">
      <% Decidim::ContentBlock.for_scope(:homepage, organization: current_organization).each do |content_block| %>
        <% next unless content_block.manifest && content_block.manifest.name == :highlighted_processes %>
        Aktualnie ustawiona maksymalna liczba konsultacji:
        <%= cell(content_block.manifest.cell, content_block).max_results %>
      <% end %>
    </h2>
  </div>

  <%#= admin_filter_selector %>
</div>
<div class="table-scroll">
  <table class="table-list">
    <thead>
    <tr>
      <th>
        <%= t("models.participatory_process.fields.title", scope: "decidim.admin") %>
        <%#= sort_link(query, :title, t("models.participatory_process.fields.title", scope: "decidim.admin")) %>
      </th>
      <th>
        <%= t(".weight") %>
        <%#= sort_link(query, :weight, t(".weight"), default_order: :asc) %>
      </th>
      <th>
        <%= t("models.participatory_process.fields.created_at", scope: "decidim.admin") %>
        <%#= sort_link(query, :created_at, t("models.participatory_process.fields.created_at", scope: "decidim.admin"), default_order: :desc) %>
      </th>

      <th class="table-list__actions">
        <%= t("models.participatory_process.fields.published", scope: "decidim.admin") %>
        <%#= sort_link(query, :published_at, t("models.participatory_process.fields.published", scope: "decidim.admin")) %>
      </th>
      <th>
        <%= t("models.participatory_process.fields.actions", scope: "decidim.admin") %>
      </th>
    </tr>
    </thead>
    <tbody>
    <% main_page_processes.each do |process| %>
      <tr>
        <td>
          <%= link_to translated_attribute(process.title), decidim_participatory_processes.participatory_process_path(process) %><br>
        </td>
        <td class="table-list__date">
          <%= process.main_page_weight %>
        </td>
        <td class="table-list__date">
          <%= l process.created_at, format: :short %>
        </td>
        <td class="table-list__state">
          <% if process.published? %>
            <span class="label success !text-sm"><%= t("participatory_processes.index.published", scope: "decidim.admin") %></span>
          <% else %>
            <span class="label alert !text-sm"><%= t("participatory_processes.index.unpublished", scope: "decidim.admin") %></span>
          <% end %>
        </td>
        <td class="table-list__actions">
          <%= icon_link_to "pencil-line", decidim_participatory_processes_extended.edit_main_page_process_path(process.id), t("actions.configure", scope: "decidim.admin"), class: "action-icon--edit", method: :get %>
          <%= icon_link_to "delete-bin-line", decidim_participatory_processes_extended.main_page_process_path(process.id), t("actions.destroy", scope: "decidim.admin"), class: "action-icon--remove", method: :delete, data: { confirm: t("actions.confirm_destroy", scope: "decidim.admin") } %>
        </td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>
<%#= decidim_paginate main_page_processes %>
