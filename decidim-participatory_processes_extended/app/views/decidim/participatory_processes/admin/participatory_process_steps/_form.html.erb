<div class="form__wrapper">
  <div class="card pt-4">
    <div id="panel-title" class="card-section">
      <div class="row column">
        <%= form.translated :text_field, :title, autofocus: true %>
      </div>

      <div class="row column">
        <%= form.translated :editor, :description, toolbar: :full, lines: 15 %>
      </div>

      <div class="row column">
        <%= form.text_field :date %>
      </div>

      <div class="row column">
        <%= form.datetime_field :start_date %>
      </div>

      <div class="row column">
        <%= form.datetime_field :end_date %>
      </div>

      <div class="row column">
        <%= form.check_box :send_notifications_on_activation, label: 'Wyślij powiadomienia przy aktywacji etapu' %>
      </div>

    </div>
  </div>
</div>
