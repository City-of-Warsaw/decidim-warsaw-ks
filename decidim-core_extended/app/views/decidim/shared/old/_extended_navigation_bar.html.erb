<div class="row expanded">
  <div class="process-nav" id="subcontent"> 
    <div class="row"> 
      <button aria-haspopup="true" class="process-nav__trigger hide-for-medium" data-toggle="process-nav-content">
        <div>   
          <% default_item = active_item || items.first %>
          <span class="process-nav__link">
            <%= default_item[:name] %>
          </span>
        </div>

        <span class="show-for-sr">Menu konsultacji</span>
        <% if items.count > 1 %>
          <%= image_pack_tag "media/images/chevron-down-thick.svg", alt: "", class: 'process-nav__trigger__icon' %>
        <% end %>
      </button>
      <div class="row column process-nav__content" id="process-nav-content" data-toggler=".is-active">
        <h2 class="show-for-sr">Menu konsultacji</h2>
        <ul role="list">
          <% items.each_with_index do |item, index| %>
            <li class="<%= "is-active" if item[:active] %> <%= "hide-for-medium" if index > max_items %>">
              <%= link_to item[:url] + "#subcontent", class: "process-nav__link #{item[:active] ? 'active' : nil}" do %>
                <%= item[:name] %>
              <% end %>
            </li>
          <% end %>
        </ul>

        <% if extra_items.any? %>
          <button class="button tiny process-nav__more show-for-medium" data-toggle="process-nav__hide-content" aria-label="pozostałe pozycje menu">
           <i></i><i></i><i></i>
          </button>
          <div class="dropdown-pane process-nav__hidden-content" id="process-nav__hide-content"
               data-dropdown
               data-hover="true"
               data-hover-pane="true"
               data-v-offset="-25"
               data-position="bottom"
               data-alignment="right"> 
            <ul>
              <% extra_items.each do |item| %>
                <li class="<%= "is-active" if item[:active] %>">
                  <%= link_to item[:url] + "#subcontent", class: "process-nav__link #{item[:active] ? 'active' : nil}" do %>
                    <%= item[:name] %>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
