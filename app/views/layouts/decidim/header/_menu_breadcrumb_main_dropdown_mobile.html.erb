<div id="<%= id %>" class="menu-bar__main-dropdown">
  <div class="menu-bar__main-dropdown__top">
    <div class="mb-8">
      <%= render partial: "layouts/decidim/header/menu_form_search_mobile" %>
    </div>

    <%= mobile_breadcrumb_root_menu.render %>
    
    <div class="topbar__accesibility">
      <% page = Decidim::StaticPage.find_by(slug: 'dostepnosc') %>
      <a href="<%= page ? decidim.page_path(page) + "#subcontent" : 'https://um.warszawa.pl/dostepnosc' %>" aria-label="<%= t('layouts.decidim.header.accesibility-title') %>">
        <%= image_pack_tag 'media/images/accesibility-icon.svg', alt: "" %>
      </a>
    </div>
    <%= render partial: "layouts/decidim/header/mobile_language_choose" %>
  </div>
  <div class="menu-bar__main-dropdown__bottom">
    <div class="menu-bar__main-dropdown__bottom-left">
      <%= cell("decidim/highlighted_participatory_process", menu_highlighted_participatory_process) %>
    </div>
    <div class="menu-bar__main-dropdown__bottom-right">
      <%= cell "decidim/content_blocks/menu_breadcrumb_last_activity", current_organization %>
    </div>
  </div>
</div>
