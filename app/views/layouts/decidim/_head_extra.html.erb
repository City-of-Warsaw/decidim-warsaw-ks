<meta name="csp-nonce" content="<%= _content_security_policy_nonce(:script) %>">

<!-- decor styles -->
<style>
  <% Decidim::Area.all.each do |area| %>
    <% col = area.color.presence || area.organization.colors["primary"] %>
    <% text_col = area.text_color.presence || "white" %>
    <% class_name = "area-color-#{area.id}" %>
    <%= ".#{class_name}" %> .colored-box--alternative { background-color: <%= col %>; }
    <%= ".#{class_name}" %> > .card--process .consultation-decor .colored-box, <%= ".#{class_name}" %>.card--process .consultation-decor .colored-box { background-color: <%= col %>; }
    <%= ".#{class_name}" %> > .card--process .consultation-decor .colored-box:before, <%= ".#{class_name}" %>.card--process .consultation-decor .colored-box:before, .line-decor.<%= "#{class_name}" %>::after {
        border-left-color: <%= col %>;
        -webkit-box-shadow: -1px 0px 0px 0px <%= col %>;
        -moz-box-shadow: -1px 0px 0px 0px <%= col %>;
        box-shadow: -1px 0px 0px 0px <%= col %>;
    }

    <%= ".#{class_name}" %> .custom-area-color-headline { background-color: <%= col %>; color: <%= text_col %> }
    <%= ".#{class_name}" %> .area-color-headline { background-color: <%= col %>; color: <%= text_col %> }
    <%= ".#{class_name}" %> .steps-indicator__progress { background-color: <%= col %>; }

    <%= ".#{class_name}" %> > .card--process { outline-color: <%= col %> !important; }
    <%= ".#{class_name}" %>.card--process.card--full { outline-color: <%= col %> !important; }
    <%= ".#{class_name}" %> .card--meeting { outline-color: <%= col %> !important; }
    <%= ".#{class_name}" %> .card__header .meeting-bottom-decor { background-color: <%= col %> !important; }
    <%= ".#{class_name}" %> .card__header .meeting-bottom-decor:after { border-left-color: <%= col %> !important; }
    <%= ".#{class_name}" %>.map-meeting-card { border-bottom-color: <%= col %> !important; }
    <%= ".line-decor.#{class_name}" %> { background-color: <%= col %>; }
    /* universal styles */
    <%= ".text-color-#{class_name}" %> { color: <%= col %>; }
    <%= ".bg-color-#{class_name}" %> { background-color: <%= col %>; }
  <% end %>
</style>

<% if Rails.env.production? %>
  <!-- Matomo -->
  <% content_for(:js_content) do %>
  <%= nonced_javascript_tag do %>
    var _paq = window._paq = window._paq || [];
    /* tracker methods like "setCustomDimension" should be called before "trackPageView" */
    _paq.push(["setCustomUrl",window.location.pathname + location.search]);
    _paq.push(["setDocumentTitle", document.domain + "/" + document.title]);
    _paq.push(["setCookieDomain", "//konsultacje.um.warszawa.pl"]);
    _paq.push(['setCookiePath', '/']);
      _paq.push(['trackPageView']);
    _paq.push(['enableLinkTracking']);
    (function() {
      var u="https://collect-stat.um.warszawa.pl/";
      _paq.push(['setTrackerUrl', u+'matomo.php']);
      _paq.push(['setSiteId', '735']);
      var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
      g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
    })();

    <!-- End Matomo Code -->
    var _mtm = window._mtm = window._mtm || [];
    _mtm.push({'mtm.startTime': (new Date().getTime()), 'event': 'mtm.Start'});
    (function() {
    var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
    g.async=true; g.src='https://collect-stat.um.warszawa.pl/js/container_4MlLuTkS.js'; s.parentNode.insertBefore(g,s);
    })();
  <% end %>
  <% end %>
<% end %>
