<% form.fields_for :settings, form.object.settings do |settings_fields| %>
  <%= settings_fields.translated :editor, :lead, label: t(".lead"), lines: 8 %>

  <%= settings_fields.translated :editor, :introduction, label: t(".introduction") %>

  <%= settings_fields.translated :editor, :body, label: t(".body") %>

  <%= settings_fields.editor :footer, toolbar: :full, label: "Stopka" %>
<% end %>

<% form.fields_for :images, form.object.images do |images_fields| %>
  <%= images_fields.upload :main_image, button_class: "button button__sm button__transparent-secondary", label: t(".main_image") %>
<% end %>

<div class="row column">
  <%= t(".interpolations_hint") %>
</div>
