<% if organization_primary_color %>
<style>
  .flexed-paragraph table td {
    color: #ffffff;
    font-size: 16px;
    display: inline-block;
    border-radius: 3px;
    min-width: 120px;
    text-align: center !important;
    padding: 10px 16px;
    background-color: <%= organization_primary_color %>;
  }

  .encouragement {
    font-size: 20px;
    max-width: calc(100% - 120px);
    padding-right: 8px;
    padding-left: 8px;
    color: <%= organization_primary_color %> !important;
    text-transform: uppercase;
    vertical-align: middle;
    line-height: 40px;
  }

  .editor-content h2 {
    border-left: 5px solid <%= organization_primary_color %>;
    padding-left: 16px;
  }

  .shadowed img { 
    filter: brightness(70%);
  }
</style>
<% end %> 

<table class="ks-custom-container">
  <tr>
    <td class="decidim-bar">
      <table class="row collapse" style="width: 100%">
        <tr style="vertical-align: middle;">
          <th class="columns decidim-bar" style="width: 100%; background-color: #ffffff;">
            <div style="text-align: center;">
              <%= logo_or_name_link %>
            </div>
          </th> 
        </tr>
      </table>
    </td>
  </tr>

  <tr class="gray-halved-bg">
    <td class="real-content">
      <% if has_main_image? %>
        <table class="row content image">
          <tr>
            <th class="small-12 first columns relative">
              <div class="relative z-1">
                <div class="shadowed"><%= main_image %></div>
                <div class="header-box">
                  <h1>
                    <%= title %>
                  </h1>
                </div>
                <div class="consultation-decor">
                  <div class="left">
                    <div class="colored-box">
                      <div class="colored-box-before"></div>
                    </div>
                    <div class="left-before"></div>
                    <div class="left-after"></div>
                  </div>
                  <div class="right">
                    <div class="right-before"></div>
                    <div class="right-after"></div>
                  </div>
                </div>
              </div>
              
              <div class="gray-background-element-image"></div>
            </th>
            <th class="expander"></th>
          </tr>
        </table>
      <% end %>
    </tr>
  </td>

  <tr class="gray-bg">
    <td class="real-content">
      <table class="row content <%= has_main_image? ? "has-image" : "no-image" %>">
        <tr>
          <th class="small-12 first columns">
            <div class="lead">
              <div class="editor-content">
                <%= lead %>
              </div> 
            </div>
          </th>
          <th class="expander"></th>
        </tr>
      </table>
    </tr>
  </td>
      
  <tr>
    <td class="real-content pt-8">
      <table class="row content">
        <tr>
          <th class="small-12 first columns">
            <span class="introduction editor-content"><%= introduction %></span>

            <% if has_cta? %>
              <p>&nbsp;</p>
              <div class="flexed-paragraph">
                <span class="encouragement"><%= encouragement %></span>

                <table class="encouragement-btn" cellspacing="0" cellpadding="0">
                  <tr>
                    <td>
                      <%= link_to cta_text, cta_url, target: :blank %>
                    </td>
                  </tr>
                </table>
              </div>
              <p>&nbsp;</p>
            <% end %>
          </th>
          <th class="expander"></th>
        </tr>
      </table>
    </td>
  </tr> 

  <tr class="gray-bg">
    <td class="real-content">
      <table class="row content mt-8">
        <tr>
          <th class="small-12 first columns"> 
            <div class="editor-content">
              <%= body %>
            </div>  
          </th>
          <th class="expander"></th>
        </tr>
      </table>
    </td>
  </tr> 

  <tr class="gray-bg">
    <td class="real-content">
      <table class="row">
        <tr>
          <th class="expander"></th>
          <th class="small-12 first columns cityhall-bar">
            <div class="decidim-logo" style="float: right; text-align: right; padding-right: 16px">
            </div>
          </th>
        </tr>
      </table>
    </td>
  </tr>
</table>
