<% add_decidim_page_title(t(".title")) %>
<div class="item_show__header">
  <h1 class="item_show__header-title">
    <%= t(".title") %>
  </h1>
</div>

<div class="item__edit item__edit-1col">
  <div class="item__edit-form">
    <% url = attached_to.is_a?(Decidim::ConsultationRequests::ConsultationRequest) ? url_for([:admin, @attachment.attached_to, @attachment]) : url_for([@attachment.attached_to, @attachment]) %>
    <%= decidim_form_for(@form, url: url, html: { class: "form form-defaults edit_attachment" }) do |f| %>
      <%= render partial: "decidim/admin/attachments/form", object: f %>

      <div class="item__edit-sticky">
        <div class="item__edit-sticky-container">
          <%= f.submit t(".update"), class: "button button__sm button__secondary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>