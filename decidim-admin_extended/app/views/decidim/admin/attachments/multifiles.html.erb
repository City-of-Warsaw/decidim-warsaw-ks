<% add_decidim_page_title(t(".title")) %>
<div class="item_show__header">
  <h1 class="item_show__header-title">
    <%= t(".title") %>
  </h1>
</div>

<div class="item__edit item__edit-1col">
  <div class="item__edit-form">
    <div class="form__wrapper">
      <div class="card pt-4">
        <div class="card-section">
          <%= decidim_form_for(@form, url: participatory_processes_attachments_create_multifiles_path, html: { class: "form form-defaults edit_attachment" }) do |form| %>
            <div class="row column">
              <%= form.select :attachment_collection_id, @form.attachment_collections.collect { |c| [translated_attribute(c.name), c.id] }, include_blank: true %>
            </div>

            <div class="row column">
              <div class="multifile-attachments">
                <div class="multifile-attachments__dropzone" data-url="<%= Rails.application.class.routes.url_helpers.rails_direct_uploads_path %>" data-max-size="<%= form.max_file_size(@form, :file) / 1000000 %>" data-allowed-extensions="<%= Decidim.organization_settings(@form).upload_allowed_file_extensions.map { |ext| ".#{ext}" }.join(",") %>">
                  <div class="multifile-attachments__dropzone-placeholder">
                    <span>
                      <%= icon "upload-cloud-2-line", class: "w-8 h-8 text-gray fill-current" %>
                      <%= t(".dropzone") %>
                    </span> 
                    
                    <label class="button button__sm button__secondary !text-white">
                      <span><%= t(".select_files") %></span>
                      <%= icon "arrow-right-line", class: "fill-current" %>
                    </label>
                  </div>
                </div>

                <div class="multifile-attachments__text"> 
                  <ul>
                    <% form.upload_help(@form, :file).each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>

                <div class="table-scroll mt-4 hidden">
                  <table class="table-list table-fixed">
                    <thead>
                      <tr>
                        <th class="w-1/3">
                          <%= t(".filename") %>
                        </th> 

                        <th class="w-1/3">
                          <%= t(".attachment_name") %>
                        </th>

                        <th class="w-1/6">
                          <%= t(".weight") %>
                        </th>

                        <th class="w-1/6">        
                          <%= t(".actions") %>
                        </th>
                      </tr>
                    </thead>

                    <tbody id="multifile-attachments_previews">
                      <tr id="multifile-attachments_template"> 
                        <td class="relative">
                          <p data-dz-name></p>
                          <span data-dz-uploadprogress></span>
                          <span data-dz-errormessage></span>
                        </td> 

                        <td>
                          <input name="attachments[files_info][][title]" type="text" required="required" />
                        </td>

                        <td >
                          <input name="attachments[files_info][][weight]" type="number" value="0" />
                        </td>

                        <td>        
                          <%= icon_link_to "delete-bin-line", "", t("actions.destroy", scope: "decidim.admin"), class: "action-icon--remove", data: { "dz-remove": "" } %>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div> 
              </div> 
            </div>  

            <div class="item__edit-sticky">
              <div class="item__edit-sticky-container">
                <%= form.submit t(".submit"), class: "button button__sm button__secondary" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<%= append_javascript_pack_tag "multifile_attachments" %>