<% add_decidim_page_title(t("decidim.admin.titles.users")) %>
<div class="card">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <%= t "decidim.admin.titles.users" %>
    <% if allowed_to? :read, :admin_user %>
      <%= link_to 'Eksport XLSX', export_users_path(format: :xlsx), class: "button button__sm button__secondary tiny" %>
      <% end %>
    </h1>

  </div>
  <%= admin_filter_selector %>
  <div class="table-scroll">
    <table class="table-list">
      <thead>
      <tr>
        <th><%= sort_link(query, :ad_role, t("models.user.fields.ad_role", scope: "decidim.admin"), default_order: :desc) %></th>
        <th><%= sort_link(query, :last_name, t("models.user.fields.name_and_surname", scope: "decidim.admin"), default_order: :desc) %></th>
        <th><%= sort_link(query, :email, t("models.user.fields.email", scope: "decidim.admin"), default_order: :desc) %></th>
        <th><%= sort_link(query, :office_name, t("models.user.fields.office_name", scope: "decidim.admin"), default_order: :desc) %></th>
        <th><%= sort_link(query, :last_sign_in_at, t("models.user.fields.last_sign_in_at", scope: "decidim.admin"), default_order: :desc) %></th>
        <th><%= sort_link(query, :ad_access_deactivate_date, t("models.user.fields.ad_access_deactivate_date", scope: "decidim.admin"), default_order: :desc) %></th>
        <th><%= sort_link(query, :editorial, t("models.user.fields.editorial", scope: "decidim.admin"), default_order: :desc) %></th>
        <th></th>
      </tr>
      </thead>
      <tbody>
      <% @users.each do |user| %>
        <tr data-user-id="<%= user.id %>">
          <td><%= user.role_name ? user.role_name : '-' %></td>
          <td><%= user.name_and_surname %></td>
          <td><%= user.email %></td>
          <td><%= user.office_name %>
          <td>
            <% if user.last_sign_in_at %>
              <%= l user.last_sign_in_at, format: :short %>
            <% end %>
          </td>
          </td>
          <td>
            <% if user.ad_access_deactivate_date %>
              <%= l user.ad_access_deactivate_date, format: :short %>
            <% end %>
          </td>
          <td><%= user.editorial.present? ? user.editorial : "-" %></td>
          <td class="table-list__actions">
            <% if allowed_to? :update, :admin_user, user: user %>
              <%= icon_link_to "pencil-line", [:edit, user], t("actions.edit", scope: "decidim.admin"), class: "action-icon--edit", method: :get, data: {} %>
            <% end %>
            <% if user.ad_access_deactivate_date.present? && allowed_to?(:edit, :admin_user, user: user) %>
              <%= icon_link_to "eye-line", [:activate_ad, user], t("actions.activate", scope: "decidim.admin"), method: :patch %>
            <% end %>
            <% if user.ad_access_deactivate_date.nil? && allowed_to?(:edit, :admin_user, user: user) %>
              <%= icon_link_to "forbid-2-line", [:deactivate_ad, user], t("actions.hide", scope: "decidim.admin"), method: :patch, class: "action-icon--hide" %>
            <% end %>
          </td>
        </tr>
      <% end %>
      </tbody>
    </table>
  </div>
</div>
<%= decidim_paginate @users %>
