<div class="answer-questionnaire__single-option js-check-box-collection">
  <small class="form-error is-visible w-full is-invalid-input">
    <%= answer_form.object.errors[:selected_choices].join(", ") %>
  </small>
  <% answers = answer.question.random_order ? answer.question.answer_options.shuffle : answer.question.answer_options
     answers.each_with_index do |answer_option, idx| %>
    <% choice = answer.selected_choices.find { |choice| choice.answer_option_id == answer_option.id } %>
    <% user_response = responses_for_current_question(answer.question) %>

    <div class="js-collection-input">
      <%= label_tag do %>
        <%= check_box_tag "questionnaire[responses][#{answer_idx}][choices][#{idx}][body]",
                          translated_attribute(answer_option.body),
                          choice.present? || user_response.pluck(:decidim_answer_option_id).include?(answer_option.id), disabled: %>

        <%= translated_attribute(answer_option.body) %>

        <%= hidden_field_tag "questionnaire[responses][#{answer_idx}][choices][#{idx}][answer_option_id]", answer_option.id %>
      <% end %>

      <% if answer_option.free_text %>
        <%= text_field_tag "questionnaire[responses][#{answer_idx}][choices][#{idx}][custom_body]",
        choice.try(:custom_body) || user_response.select {|e| e.decidim_answer_option_id == answer_option.id}&.first&.custom_body,
        disabled: true,
        maxlength:,
        class: "w-full" %>
      <% end %>
    </div>
  <% end %>
</div>
