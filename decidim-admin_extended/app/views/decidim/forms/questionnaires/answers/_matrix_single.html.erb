<% answers_rows = answer.question.random_order? ? answer.question.matrix_rows.shuffle(random: Random.new()) : answer.question.matrix_rows.by_position %>
<div class="answer-questionnaire__single-matrix">
  <small class="form-error is-visible w-full is-invalid-input">
    <%= answer_form.object.errors[:choices].join(", ") %>
  </small>
  <table>
    <thead>
      <tr>
        <td></td>
        <% answer.question.answer_options.each_with_index do |answer_option, idx| %>
          <th><%= translated_attribute(answer_option.body) %></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% answers_rows.each_with_index do |row, row_idx| %>
        <tr class="js-radio-button-collection">
          <td><%= translated_attribute row.body %></td>
          <% answer.question.answer_options.each_with_index do |answer_option, idx| %>
            <% choice = answer.choices.find { |choice| choice.answer_option_id == answer_option.id && choice.matrix_row_id == row.id } %>
            <% choice_id = "#{field_id}_matrix_row_#{row_idx}_choice_#{idx}" %>
            <td>
              <div class="js-collection-input">
                <%= radio_button_tag "questionnaire[responses][#{answer_idx}][choices][#{row_idx}][body]",
                                     translated_attribute(answer_option.body),
                                     choice || matrix_answer_checked?(answer.question, row, answer_option),
                                     "aria-label": translated_attribute(answer_option.body),
                                     id: "#{choice_id}_body", disabled: %>
                <%= hidden_field_tag "questionnaire[responses][#{answer_idx}][choices][#{row_idx}][answer_option_id]",
                                     answer_option.id,
                                     id: "#{choice_id}_answer_option",
                                     disabled: true %>
                <%= hidden_field_tag "questionnaire[responses][#{answer_idx}][choices][#{row_idx}][matrix_row_id]",
                                     row.id,
                                     id: "#{choice_id}_matrix_row",
                                     disabled: true %>
                <% if answer_option.free_text %>
                  <%= text_field_tag "questionnaire[responses][#{answer_idx}][choices][#{row_idx}][custom_body]",
                                     choice.try(:custom_body) || matrix_answer_body(answer.question, row, answer_option),
                                     id: "#{choice_id}_custom_body",
                                     disabled: true,
                                     maxlength: %>
                <% end %>
              </div>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% content_for(:js_content) do %>
<%= nonced_javascript_tag do %>
  $(document).ready(function() {
    function handleRadioSelection(selectedRadioButton) {
      const row = selectedRadioButton.closest('tr');

      row.find('input[type="hidden"]').prop('disabled', true);
      row.find('input[type="text"]').prop('disabled', true);

      const selectedCell = selectedRadioButton.closest('.js-collection-input');
      selectedCell.find('input[type="hidden"]').prop('disabled', false);
      selectedCell.find('input[type="text"]').prop('disabled', false);
    }

    $('.js-radio-button-collection').each(function() {
      // klikanie w tekstowy input nie powinno niczego robic
      if (e.target.type === 'text') {
        return;
      }

      $(this).find('td:not(:first-child)').on('click', function() {
        const radioButton = $(this).find('input[type="radio"]');

        if (radioButton.length) {
          $(this).closest('tr').find('input[type="radio"]').prop('checked', false);
          radioButton.prop('checked', true);
          handleRadioSelection(radioButton);
        }
      });
    });

    $('.js-radio-button-collection input[type="radio"]').on('change', function() {
      if ($(this).prop('checked')) {
        handleRadioSelection($(this));
      }
    });
  });
<% end %>
<% end %>
