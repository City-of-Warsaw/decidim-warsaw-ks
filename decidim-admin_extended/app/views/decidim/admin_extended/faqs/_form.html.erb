<div class="form__wrapper">
  <div class="card pt-4">
    <div class="row column">
      <%= form.text_field :title, autofocus: true %>
    </div>

    <div class="row column">
      <%= form.editor :content, toolbar: :full, lines: 25 %>
    </div>

    <div class="row column">
      <%= form.label :published %>
      <%= form.radio_button :published, false, label: t(".published_no") %>
      <%= form.radio_button :published, true, label: t(".published_yes") %>
    </div>

    <div class="row column">
      <%= form.number_field :weight %>
    </div>

    <div class="row column">
      <%= form.collection_select :faq_group_id, faq_groups, :id, :title %>
    </div>
  </div>
</div>
