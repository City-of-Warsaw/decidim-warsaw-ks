<% add_decidim_page_title(statistic.name) %>
<div class="item_show__header">
  <h1 class="item_show__header-title">
    <%= statistic.sys_name.present? ? t(".title", name: t(statistic.sys_name, scope: 'decidim.admin_extended.statistics.sys_name'), count: statistic.count) : statistic.name %>
  </h1>
</div>
<div class="item__edit-form">
  <%= decidim_form_for(@form, html: { class: "form-defaults form scope_types_edit" }) do |f| %>
    <div class="card">
      <div class="card-section">
        <%= render partial: "form", object: f %>
      </div>
    </div>
    <div class="item__edit-sticky">
      <div class="item__edit-sticky-container">
        <%= f.submit t(".update"), class: "button button__sm button__secondary" %>
      </div>
    </div>
  <% end %>
</div>
