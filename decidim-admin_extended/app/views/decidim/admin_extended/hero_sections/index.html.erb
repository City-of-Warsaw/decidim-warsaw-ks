<% add_decidim_page_title(t("hero_sections.title", scope: "decidim.admin")) %>
<div class="card">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <%= t("hero_sections.title", scope: "decidim.admin") %>
    </h1>
  </div>

  <div class="card-section">
    <div class="table-scroll">
      <table class="table-list">
        <thead>
          <th><%= t(".headers.name") %></th>
          <th><%= t(".headers.updated_at") %></th>
          <th></th>
        </thead>

        <tbody>
        <% hero_sections_admin.each do |section| %>
          <tr>
            <td>
              <%= section.title %>
            </td>
            <td>
              <%= l(section.updated_at, format: :decidim_short_cut_zero) %>
            </td>
            <td class="table-list__actions">
              <% if allowed_to? :manage, :hero_sections %>
                <%= icon_link_to "pencil-line", [:edit, section], t("actions.edit", scope: "decidim.admin"), class: "action-icon--edit", method: :get, data: {} %>
                <%= icon_link_to "eye-line", decidim_admin_extended.hero_section_path(section), t("actions.preview", scope: "decidim.admin"), class: "action-icon--preview" %>
              <% end %>
            </td>
          </tr>
        <% end %>
        <tbody>
      </table>
    </div>
  </div>
</div>
