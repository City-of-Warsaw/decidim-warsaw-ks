<% add_decidim_page_title(t("decidim.admin.titles.consultation_requests")) %>
<div class="card">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <%= t "decidim.admin.titles.consultation_requests" %>
      <% if allowed_to? :update, :organization, organization: current_organization %>
        <%= link_to "Nowy wniosek", [:new, :admin, :consultation_request], class: "button button__sm button__secondary" %>
      <% end %>
    </h1>
  </div>

  <div class="table-scroll">
    <table class="table-list">
      <thead>
        <tr>
          <th><%= t("models.consultation_request.fields.title", scope: "decidim.admin") %></th>
          <th><%= t("models.consultation_request.fields.applicant", scope: "decidim.admin") %></th>
          <th><%= t("models.consultation_request.fields.date_of_request", scope: "decidim.admin") %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @consultation_requests.each do |consultation_request| %>
          <tr>
            <td>
              <% if allowed_to? :update, :organization, organization: current_organization %>
                <%= link_to consultation_request.title, [:edit, :admin, consultation_request] %>
              <% else %>
                <%= consultation_request.title %>
              <% end %>
            </td>
            <td>
              <%= consultation_request.applicant %>
            </td>
            <td>
              <%= consultation_request.date_of_request && l(consultation_request.date_of_request, format: :decidim_short_cut_zero) %>
            </td>
            <td class="table-list__actions">
              <% if allowed_to? :update, :organization, organization: current_organization %>
                <%= icon_link_to "pencil-line",
                                 [:edit, :admin, consultation_request],
                                 t("actions.edit", scope: "decidim.admin"),
                                 class: "action-icon--edit",
                                 method: :get, data: {} %>
                <%= icon_link_to "eye-line",
                                 consultation_request_path(consultation_request),
                                 t("actions.preview", scope: "decidim.admin"),
                                 class: "action-icon--preview" %>
                <%= icon_link_to "delete-bin-line",
                                 [:admin, consultation_request],
                                 t("actions.destroy", scope: "decidim.admin"),
                                 class: "action-icon--remove", method: :delete,
                                 data: { confirm: t("actions.confirm_destroy", scope: "decidim.admin") } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= decidim_paginate @consultation_requests %>
