<% add_decidim_page_title(t(".title")) %>
<div class="item_show__header">
  <h1 class="item_show__header-title">
    <%= t ".title" %>
  </h1>
</div>
<div class="item__edit-form">
  <%= decidim_form_for(@form, url: new_file_submit_url, html: { autocomplete: 'off', class: "form-defaults form scope_types_new" }) do |f| %>
    <div class="card">
      <div class="card-section">
        <% if @gallery %>
          <%= render partial: "add_file_to_gallery_form", object: f %>
        <% else %>
          <%= render partial: "form", object: f %>
        <% end %>
      </div>
    </div>
    <div class="item__edit-sticky">
      <div class="item__edit-sticky-container">
        <%= link_to 'Anuluj', admin_files_path, class: "button button__sm button__secondary" %>
        <%= f.submit t(".create"), class: "button button__sm button__secondary" %>
      </div>
    </div>
  <% end %>
</div>
