<!DOCTYPE html>
<html>
  <head>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%# Customization: Removed %>
    <%#= legacy_favicon %>
    <%#= favicon %>
    <%#= apple_favicon %>
    <%= append_stylesheet_pack_tag "decidim_admin_overrides", media: "all" %>
    <%= stylesheet_pack_tag "decidim_core", "decidim_admin", media: "all" %>
    <%= append_javascript_pack_tag "admin_custom" %>
    <%= javascript_pack_tag "decidim_core", "decidim_admin", defer: false %>

    <!-- added script: -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/js/select2.min.js" integrity="sha512-4MvcHwcbqXKUHB6Lx3Zb5CEAVoE9u84qN+ZSMM6s7z8IeJriExrV3ND5zRze9mxNlABJ6k864P/Vl8m0Sd3DtQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <%= organization_colors %>
    <%= snippets.display(:head) %>
    <meta name="csp-nonce" content="<%= _content_security_policy_nonce(:script) %>">
  </head>

  <body>
    <div class="card">
      <div class="card-section">
        <% if @files.any? %>
          <%= decidim_form_for(@form, method: :get, url: editor_images_admin_files_path, html: { autocomplete: 'off', class: "" }) do |f| %>
            <div class="row column" style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
              <%= f.text_field :name, class: "search-input", label: false, placeholder: "Nazwa" %>
              <%= f.submit t(".search"), class: "button button__sm button__secondary" %>
            </div>

            <%= render 'decidim/repository/admin/files/tiles', show_select_buttons: true %>
            <%= paginate @files, theme: "decidim" %>
          <% end %>
        <% else %>
          <p><%= t("decidim.admin.repository.no_files") %></p>
        <% end %>
      </div>
    </div>
  </body>
</html>
