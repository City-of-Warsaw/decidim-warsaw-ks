<% add_decidim_page_title(t("decidim.admin.titles.files")) %>

<div class="card">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <%= @folder.name %> / <%= t "decidim.admin.titles.files" %>

      <%= render partial: "decidim/repository/admin/switch_between_tiles_or_list" %>

      <%= link_to t("actions.add_file", scope: "decidim.admin"),
                  decidim_repository.new_admin_folder_file_path(@folder),
                  class: "button button__sm button__secondary" %>
    </h1>
  </div>

  <%= render partial: "decidim/repository/admin/filters" %>
  <%= render partial: "decidim/repository/admin/tiles_or_list" %>
</div>
