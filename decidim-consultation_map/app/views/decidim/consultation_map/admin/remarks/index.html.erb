<% add_decidim_page_title(t(".title")) %>
<div class="card">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <%= t(".title") %>
      <%= link_to 'Eksport XLS', { action: :export, format: :xlsx }, class: "button button__sm button__secondary" %>
      <% if allowed_to? :manage, :map_remark_category %>
        <%= link_to 'Kategorie', categories_path, class: "button button__sm button__secondary" %>
        <%= link_to 'Podkłady mapowe', map_backgrounds_path, class: "button button__sm button__secondary" %>
      <% end %>
    </h1>
  </div>

  <div class="table-scroll">
    <table class="table-list">
      <thead>
        <th><%= t("models.remark.fields.author_name", scope: "decidim.consultation_map") %></th>
        <th><%= t("models.remark.fields.body", scope: "decidim.consultation_map") %></th>
        <th><%= t("models.remark.fields.files", scope: "decidim.consultation_map") %></th>
        <th><%= t("models.remark.fields.created_at", scope: "decidim.consultation_map") %></th>
        <th class="actions"><%= t("actions.title", scope: "decidim.consultation_map.admin") %></th>
      </thead>
      <tbody>
        <% @remarks.each do |remark| %>
          <tr data-id="<%= remark.id %>">
            <td>
              <% if remark.author.is_a? Decidim::User %>
                <%= remark.author.name %>
              <% else %>
                <%= t("decidim.author.unregistered_author") %>
              <% end %>
            </td>
            <td>
              <%= decidim_sanitize html_truncate(remark.body, max_length: 50) %>
            </td>

            <td>
              <%= remark.files.attached? ? 'Tak' : '-' %>
            </td>

            <td>
              <%= l remark.created_at, format: "%d/%m/%Y - %H:%M" %>
            </td>
            <td class="table-list__actions">
              <% if remark.files.attached? %>
                <%= icon_link_to "pencil-line", [:edit, remark], t("actions.edit", scope: "decidim.admin"), class: "action-icon--edit", method: :get, data: {} %>
              <% end %>
              <%= icon_link_to "eye-line", resource_locator(remark).path, t("actions.preview", scope: "decidim.consultation_map.admin"), class: "action-icon--preview", target: :blank %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <%= paginate @remarks, theme: "decidim" %>
  </div>
</div>