<% add_decidim_page_title(t(".title")) %>
<div class="card">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <%= t(".title") %>
      <%= link_to 'Powrót do Uwag na mapie', remarks_path, class: "button button__sm button__secondary" %>
      <%= link_to "Dodaj kategorię", new_category_path, class: "button button__sm button__secondary" %>
    </h1>
  </div>
  <div class="card-section svg_color">
    <div class="table-scroll">
      <table class="table-list">
        <thead>
        <th>Nazwa</th>
        <th>Ikona</th> 
        <th class="actions"></th>
        </thead>
        <tbody>
        <% @categories.each do |category| %>
          <tr data-id="<%= category.id %>">
            <td>
              <%= category.name %>
            </td>
            <td class="text-center">
              <div style="background-color: <%= category.color %>;" class="w-10 h-10 rounded-full inline-flex items-center justify-center *:w-6 *:h-6 *:invert">
                <% unless category.file_id.nil? %>
                      <%= raw category.inline_svg(category.file) %>
                  <% end %>
              </div>
            </td> 
            <td class="table-list__actions">
              <%= icon_link_to "eye-line",category_path(category),t("actions.preview", scope: "decidim.admin"), class: "action-icon--preview" %>
              <%= icon_link_to "pencil-line", edit_category_path(category), t("actions.edit", scope: "decidim.admin"), class: "action-icon--edit", method: :get, data: {} %>
              <%= icon_link_to "delete-bin-line", category_path(category), t("actions.destroy", scope: "decidim.admin"), class: "action-icon--remove", method: :delete, data: { confirm: t("actions.confirm_destroy", scope: "decidim.admin") } %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
      <%= paginate @categories, theme: "decidim" %>
    </div>
  </div>
</div>
<%= append_javascript_pack_tag "color_svg" %>
