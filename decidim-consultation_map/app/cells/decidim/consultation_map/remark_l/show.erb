<div class="card" id="<%= dom_id(model) %>">
  <div class="card__header card__header--sm-padding">
    <div class="author-data">
      <div class="author-data__main">
        <%== cell("decidim/author", author_presenter) %>
        <%= time_tag model.created_at, l(model.created_at, format: :decidim_short_cut_zero) %>

        <div class="relative ml-auto">
          <button class="!block text-primary font-bold text-sm leading-5 -mt-1" id="dropdown-trigger-<%= model.id %>" data-component="dropdown" data-target="dropdown-menu-<%= model.id %>" aria-label="<%= t("decidim.components.comment.controls_label") %>">
            &#8230;
          </button>

          <div id="dropdown-menu-<%= model.id %>" aria-hidden="true">
            <ul class="dropdown dropdown__bottom divide-y divide-gray-3 px-4">
              <li>
                <%= cell("decidim/report_button", model, only_button: true, button_classes: "dropdown__item flex-row-reverse", modal_id: "flagModalRemark#{model.id}") %>
              </li>

              <% if frontend_administrable? %>
                <li>
                  <%= cell("decidim/hide_button", model, only_button: true, button_classes: "dropdown__item flex-row-reverse", modal_id: "flagHideModalComment#{model.id}") %>
                </li>
              <% end %>

              <li>
                <%= link_to "#{remarks_path}?remarkId=#{model.id}", target: "_blank", data: { "external-link": "text-only" }, class: "dropdown__item", title: t("decidim.components.comment.single_comment_link_title") do %>
                  <%= icon "share-line" %>
                  <span><%= t("decidim.components.comment.single_comment_link_title") %></span>
                <% end %>
              </li>

              <% if !current_user && model.allow_edition?(remark_token) %>
                <li>
                  <%= link_to edit_link,
                    class: 'dropdown__item',
                    remote: true,
                    data: { id: model.id, } do %> 
                    <%= icon "edit-line" %>
                    <span><%= t("decidim.components.comment.edit") %></span>
                  <% end %>
                </li>
              <% end %> 

              <% if model.authored_by?(current_user) %>
                <li>
                  <%= link_to edit_link,
                    class: 'dropdown__item',
                    remote: true,
                    data: { id: model.id } do %> 
                    <%= icon "edit-line" %>
                    <span><%= t("decidim.components.comment.edit") %></span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card__content remark__body">
    <div class="card__text">
      <div class="card__text--paragraph editor-content editor-content--map-remark">
        <%= description %>
      </div>
    </div>

    <% model.files.each do |file| %>
      <% if file.image? %>
        <div class="single-image">
          <%= link_to Rails.application.routes.url_helpers.rails_representation_path(file.variant(resize: "900x900").processed, only_path: true), name: "link", class: 'swipebox', rel: dom_id(model) do %>
            <%= image_tag(Rails.application.routes.url_helpers.rails_representation_path(file.variant(resize: "200x200^").processed, only_path: true), class: 'thumbnail') %>
            <%= image_pack_tag "media/images/zoom-icon.svg", alt: file.blob.metadata['alt'], class: 'zoom-icon' %>
          <% end %>
        </div>
      <% else %>
        <div class="single-file">
          <div class="single-file__text">
            <div>
              <a href="<%= Rails.application.routes.url_helpers.rails_blob_path(file, only_path: true) %>" class="card__link" data-external-link="text-only" target="_blank">
                <h4 class="single-file__heading">
                  <%= file.filename %>
                </h4>
              </a>

              <small class="block">
                <%= file.filename.extension_without_delimiter.upcase %>,
                <%= '%.2f' % ((file.byte_size / 1024000.0).ceil(2)) %> MB
              </small>
            </div>
          </div>
          <div class="single-file__data">
            <%= link_to Rails.application.routes.url_helpers.rails_blob_path(file, only_path: true), target: "_blank", rel: "noopener", class: "card--list__data__icon", data: { "external-link": "false" }, title: t("decidim.components.component.download_file") do %>
              <%= icon "download-2-line" %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>

  <%= comments_for model %>
</div>

<% if current_user.present? %>
  <%= cell("decidim/report_button", model, modal_id: "flagModalRemark#{model.id}").flag_modal %>
<% end %>

<% if frontend_administrable? %>
  <%= cell("decidim/hide_button", model, modal_id: "flagHideModalComment#{model.id}").flag_modal %>
<% end %>

<div class="remark-box__category" style="background-color: <%= model.category&.color %>;">
  <%= raw model.category&.inline_svg(model.category&.file) %>
  <%= model.category&.name %>
</div>