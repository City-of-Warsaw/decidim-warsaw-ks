<% add_decidim_page_title(t("decidim.admin.titles.informations")) %>

<div class="card">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <%= t "decidim.admin.titles.informations" %>
      <% if allowed_to? :update, :organization, organization: current_organization %>
        <%= link_to t("informations.new.create", scope: "decidim.admin"), [:new, :information], class: "button button__sm button__secondary" %>
      <% end %>
    </h1>
  </div>

  <div class="table-scroll">
    <table class="table-list">
      <thead>
        <tr>
          <th><%= t(".title") %></th>
          <th><%= t(".body") %></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @informations.each do |information| %>
          <tr>
            <td>
              <% if allowed_to? :update, :organization, organization: current_organization %>
                <%= link_to information.title, [:edit, information] %>
              <% else %>
                <%= information.title %>
              <% end %>
            </td>
            <td>
              <%= decidim_sanitize html_truncate(information.body, length: 50, separator: "..."), strip_tags: %w[img video] %>
            </td>
            <td class="table-list__actions">
              <% if allowed_to? :update, :information, information: information %>
                <%= icon_link_to "pencil-line",
                                 [:edit, information],
                                 t("actions.edit", scope: "decidim.admin"),
                                 class: "action-icon--edit",
                                 method: :get, data: {} %>

                <% if information.published? %>
                  <%= icon_link_to "close-line",
                                   unpublish_information_path(information),
                                   t("actions.unpublish", scope: "decidim.admin"),
                                   class: "action-icon--unpublish",
                                   method: :patch %>
                <% else %>
                  <%= icon_link_to "check-line",
                                   publish_information_path(information),
                                   t("actions.publish", scope: "decidim.admin"),
                                   class: "action-icon--publish",
                                   method: :patch %>

                <% end %>

                <%= icon_link_to "eye-line",
                                 news_path(information),
                                 t("actions.preview", scope: "decidim.admin"),
                                 class: "action-icon--preview" %>

                <%= icon_link_to "delete-bin-line",
                                 information_path(information),
                                 t("actions.destroy", scope: "decidim.admin"),
                                 class: "action-icon--remove",
                                 method: :delete,
                                 data: { confirm: t("actions.confirm_destroy", scope: "decidim.admin") } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<%= decidim_paginate @informations %>
