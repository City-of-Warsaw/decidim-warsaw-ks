<% if current_component.ai_enabled? %>
  <button class="button button__sm button__secondary" data-toggle="ai-functions-dropdown">
    Funkcje AI
    <%= icon "arrow-down-s-line", class: "dropdown-filter-icon" %>
  </button>
  <div class="dropdown-pane" id="ai-functions-dropdown" data-dropdown data-auto-focus="true" data-close-on-click="true">
    <ul class="vertical menu add-components font-normal">
      <li>
        <%= link_to "Przeglądanie uwag", decidim_custom_ai_admin.answers_path %>
      </li>
      <li>
        <%= link_to "Zarządzanie tagami",decidim_custom_ai_admin.tags_path %>
      </li>
      <li>
        <%= link_to "Zarządzanie plikami",decidim_custom_ai_admin.files_path%>
      </li>
      <li>
        <%= link_to "Generowanie podsumowań", decidim_custom_ai_admin.ai_generate_summary_path %>
      </li>
    </ul>
  </div>
<% end %>
