<% add_decidim_page_title(t(".title")) %>
<div class="item_show__header">
  <h1 class="item_show__header-title">
    <%= t ".title" %>
  </h1>
</div>
<div class="item__edit-form">
  <%= decidim_form_for(@form, url: send_xlsx_file_files_path, html: { class: "form-defaults form" }) do |f| %>
    <div class="card">
      <div class="card-section">
        <div class="row column">
          <%= f.file_field :file, accept: FileFormValidator.accept_string_for(f.object.class, :file) %>
        </div>
      </div>
    </div>
    <div class="item__edit-sticky">
      <div class="item__edit-sticky-container">
        <%= f.submit t(".create"), class: "button button__sm button__secondary" %>
      </div>
    </div>
  <% end %>
</div>
