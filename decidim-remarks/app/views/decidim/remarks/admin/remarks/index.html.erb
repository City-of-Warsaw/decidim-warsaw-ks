<% add_decidim_page_title(t(".title")) %>
<div class="card">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <%= t(".title") %>
      <%= link_to 'Eksport XLS', export_remarks_path(format: :xlsx), class: "button button__sm button__secondary" %>
    </h1>
  </div>

  <div class="card-section">
    <div class="table-scroll">
      <table class="table-list">
        <thead>
          <th><%= t("models.remark.fields.author_name", scope: "decidim.remarks") %></th>
          <th><%= t("models.remark.fields.body", scope: "decidim.remarks") %></th>
          <th><%= t("models.remark.fields.created_at", scope: "decidim.remarks") %></th>
          <th class="actions"><%= t("actions.title", scope: "decidim.remarks.admin") %></th>
        </thead>
        <tbody>
          <% @remarks.each do |remark| %>

            <tr data-id="<%= remark.id %>">
              <td>
                <% if remark.author.is_a? Decidim::User %>
                  <%= remark.author.name %>
                <% else %>
                  <%= t("decidim.author.unregistered_author") %>
                <% end %>
              </td>
              <td>
                <%= decidim_sanitize html_truncate(remark.body, max_length: 50) %>
              </td>
              <td>
                <%= l remark.created_at, format: "%d/%m/%Y - %H:%M" %>
              </td>
              <td class="table-list__actions">
                <%= icon_link_to "pencil-line", [:edit, remark], t("actions.edit", scope: "decidim.admin"), class: "action-icon--edit", method: :get, data: {} %>
                <%= icon_link_to "eye-line", resource_locator(remark).path, t("actions.preview", scope: "decidim.remarks.admin"), class: "action-icon--preview", target: :blank %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%= decidim_paginate @remarks %>