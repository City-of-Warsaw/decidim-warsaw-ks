<% add_decidim_page_title(t(".title")) %>

<div class="card">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <%= t(".title") %>
      <% if allowed_to? :create, :expert %>
        <%= link_to t("actions.new", scope: "decidim.expert_questions.admin", name: t("models.expert.name", scope: "decidim.expert_questions")), new_expert_path, class: "button button__sm button__secondary" if (true || allowed_to?(:create, :expert)) %>
      <% end %>
      <%= link_to 'Eksport XLS', export_experts_path(format: :xlsx), class: "button button__sm button__secondary" %>
    </h1>
  </div>


  <div class="table-scroll">
    <table class="table-list">
      <thead>
        <tr>
          <th></th>
          <th><%= t("models.expert.fields.full_name", scope: "decidim.expert_questions") %></th>
          <th><%= t("models.expert.fields.description", scope: "decidim.expert_questions") %></th>
          <th><%= t("models.expert.fields.affiliation", scope: "decidim.expert_questions") %></th>
          <th><%= t("models.expert.fields.created_at", scope: "decidim.expert_questions") %></th>
          <th class="actions"><%= t("actions.title", scope: "decidim.expert_questions.admin") %></th>
        </tr>
      </thead>
      <tbody>
        <% experts.each do |expert| %>
          <tr data-id="<%= expert.id %>">
            <td><%= expert_avatar expert %></td>
            <td><%= expert.full_name %></td>
            <td><%= decidim_sanitize html_truncate(expert.description, max_length: 50) %></td>
            <td><%= expert.affiliation %></td>
            <td><%= l expert.created_at, format: "%d/%m/%Y - %H:%M" %></td>
            <td class="table-list__actions">
              <% if allowed_to? :update, :expert, expert: expert %>
                <%= icon_link_to "pencil-line", edit_expert_path(expert), t("actions.edit", scope: "decidim.expert_questions.admin"), class: "action-icon--edit" %>
              <% end %>

              <% if allowed_to? :publish, :expert %>
                <% if expert.published? %>
                  <%= icon_link_to "close-circle-line", unpublish_expert_path(expert), t("actions.unpublish", scope: "decidim.admin"), class: "action-icon--unpublish", method: :put %>
                <% else %>
                  <%= icon_link_to "check-line", publish_expert_path(expert), t("actions.publish", scope: "decidim.admin"), class: "action-icon--publish", method: :put %>
                <% end %>
              <% else %>
                <span class="action-space icon"></span>
              <% end %>

              <% if allowed_to? :read, :expert_answer, expert: expert %>
                <%= icon_link_to "list-check", expert_user_questions_path(expert), t("actions.questions", scope: "decidim.admin"), class: "action-icon--configure" %>

              <% else %>
                <span class="action-space icon"></span>
              <% end %>

              <% if allowed_to? :destroy, :expert, expert: expert %>
                <%= icon_link_to "delete-bin-line", expert_path(expert), t("actions.destroy", scope: "decidim.expert_questions.admin"), method: :delete, class: "action-icon--remove", data: { confirm: t("actions.confirm_destroy", scope: "decidim.expert_questions.admin") } %>
              <% else %>
                <span style='display: inline-block; width: 14px;' class='action-icon'></span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <%= paginate experts, theme: "decidim" %>
  </div>
</div>