<% add_decidim_page_title(t(".title")) %>
<div class="item_show__header">
  <h1 class="item_show__header-title">
    <%= t(".title") %>
  </h1>
</div>
<div class="item__edit-form">
  <%= decidim_form_for(@form, url: user_question_expert_answer_path(user_question, expert_answer), html: { class: "form form-defaults new_expert_answer" }) do |f| %>
    <%= render partial: "form", object: f %>
    <div class="item__edit-sticky">
      <div class="item__edit-sticky-container">
        <%= f.submit t(".update"), class: "button button__sm button__secondary" %>

        <% if allowed_to? :publish, :expert_answer %>
          <%#= link_to t("actions.unpublish", scope: "decidim.admin"), experts_path(expert, publish: 'true'), class: "button muted" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
