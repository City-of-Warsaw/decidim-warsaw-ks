<%= link_to resource_path, id: dom_id(resource), class: "card__search" do %>
  <%= content_tag title_tag, class: "h4 card__search-title" do %>
    <%= title %>
  <% end %>
  <%= content_tag "description", class: "card__search-description" do %>
    <%= description %>
  <% end %>
  <%= content_tag :div, class: "card__search-process-name" do %>
    <%= participatory_space_class_name %>:
    <%= content_tag :span do %>
      <%= participatory_space_title %>
    <% end %>
  <% end %>
<% end %>
