<% add_decidim_page_title(t(".title")) %>
<div class="card">
  <div class="item_show__header">
    <h1 class="item_show__header-title">
      <%= t(".title") %>
      <%= link_to 'Eksport XLS', export_custom_proposals_path(format: :xlsx), class: "button button__sm button__secondary" %>
      <% if allowed_to? :create, :custom_proposal %>
        <%= link_to "Dodaj fragment dokumentu", new_custom_proposal_path, class: "button button__sm button__secondary" %>
      <% end %>
    </h1>
  </div>

  <div class="card-section">
    <div class="table-scroll">
      <table class="table-list">
        <thead>
          <th><%= t(".weight") %></th>
          <th><%= t(".proposal_title") %></th>
          <th><%= t(".published") %></th>
          <th><%= t(".created_at") %></th>
          <th></th>
        </thead>
        <tbody>
        <% custom_proposals.each do |custom_proposal| %>
          <tr data-id="<%= custom_proposal.id %>">
            <td>
              <%= custom_proposal.weight %>
            </td>
            <td>
              <%= custom_proposal.title %>
            </td>
            <td>
              <%= custom_proposal.published.present? ? t(".published_yes") : t(".published_no") %>
            </td>
            <td>
              <%= l custom_proposal.created_at, format: :decidim_short_cut_zero %>
            </td>
            <td class="table-list__actions">
              <% if allowed_to? :update, :custom_proposal, custom_proposal: custom_proposal %>
                <%= icon_link_to "pencil-line", [:edit, custom_proposal], t("actions.edit", scope: "decidim.admin"), class: "action-icon--edit", method: :get, data: {} %>
              <% end %>
              <% if allowed_to? :destroy, :custom_proposal, custom_proposal: custom_proposal %>
                <%= icon_link_to "delete-bin-line", custom_proposal_path(custom_proposal), t("actions.destroy", scope: "decidim.admin"), class: "action-icon--remove", method: :delete, data: { confirm: t("actions.confirm_destroy", scope: "decidim.admin") } %>
              <% end %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
      <%= paginate custom_proposals, theme: "decidim" %>
    </div>
  </div>
</div>