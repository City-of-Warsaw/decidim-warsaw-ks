<main>
  <div class="participatory-space__container">     
    <section> 
      <%= render partial: 'decidim/shared/component_settings_help_section' %>
    </section> 
 
    <section class="general-plan-request-wrapper"> 
      <%= decidim_form_for(@form) do |form| %>
        <%#= invisible_captcha %> 

        <div class="form-head">
          <h2><%= t(".form_title") %></h2>

          <div>
            <%= t(".submission_date") %>
            <strong><%= Time.now.strftime("%-d.%m.%Y") %></strong>
          </div>
        </div>

        <div class="form-section">
          <button type="button" class="form-section__trigger" aria-expanded="false" data-toggle="general_plan_request_form_section_1">
            <%= image_pack_tag "media/images/chevron-down-thick.svg", alt: "", class: 'form-section__trigger-icon' %>

            <div>
              <h3><%= t(".section_1") %></h3>

              <span>
                <%= t(".prefilled") %>
              </span>

              <span class="action">
                <span expand><%= t(".expand") %></span>
                <span collapse><%= t(".collapse") %></span>
              </span>
            </div>
          </button>
          
          <div id="general_plan_request_form_section_1"  data-toggler="form-section__content--visible" class="form-section__content">
            <div class="narrow-part">
              <div class="narrow-part__fields">
                <div class="field">
                  <%= form.text_field :authority_name_which_letter_is_addressed, disabled: true, class: "mb-0" %> 
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="form-section">
          <button type="button" class="form-section__trigger" aria-expanded="false" data-toggle="general_plan_request_form_section_2">
            <%= image_pack_tag "media/images/chevron-down-thick.svg", alt: "", class: 'form-section__trigger-icon' %>
  
            <div>
              <h3><%= t(".section_2") %></h3>

              <span>
                <%= t(".prefilled") %>
              </span>

              <span class="action">
                <span expand><%= t(".expand") %></span>
                <span collapse><%= t(".collapse") %></span>
              </span>
            </div>
          </button>
          
          <div id="general_plan_request_form_section_2"  data-toggler="form-section__content--visible" class="form-section__content">
            <div class="form-section__content-checkboxes form-section__content-checkboxes--halves">
              <div class="checkboxed">
                <%= form.check_box :letter_type, disabled: true, checked: true %>
              </div>

              <div class="checkboxed">
                <input type="checkbox" disabled /> 
                <label class="styled-label"><%= t(".letter_type_2") %></label>
              </div> 
              
              <div class="checkboxed">
                <input type="checkbox" disabled /> 
                <label class="styled-label"><%= t(".letter_type_3") %></label>
              </div> 
              
              <div class="checkboxed">
                <input type="checkbox" disabled /> 
                <label class="styled-label"><%= t(".letter_type_4") %></label>
              </div>
            </div>
          </div>
        </div>

        <div class="form-section">
          <button type="button" class="form-section__trigger" aria-expanded="false" data-toggle="general_plan_request_form_section_3">
            <%= image_pack_tag "media/images/chevron-down-thick.svg", alt: "", class: 'form-section__trigger-icon' %>
  
            <div>
              <h3><%= t(".section_3") %></h3>

              <span>
                <%= t(".prefilled") %>
              </span>

              <span class="action">
                <span expand><%= t(".expand") %></span>
                <span collapse><%= t(".collapse") %></span>
              </span>
            </div>
          </button>
          
          <div id="general_plan_request_form_section_3"  data-toggler="form-section__content--visible" class="form-section__content">
            <div class="form-section__content-checkboxes">
              <div class="checkboxed">
                <%= form.check_box :urban_planning_act_type, disabled: true, checked: true %>  
              </div>

              <div class="checkboxed">
                <input type="checkbox" disabled /> 
                <label class="styled-label"><%= t(".urban_planning_act_type_2") %></label>
              </div>

              <div class="checkboxed">
                <input type="checkbox" disabled />               
                <label class="styled-label"><%= t(".urban_planning_act_type_3") %></label>
              </div>

              <div class="checkboxed">
                <input type="checkbox" disabled />
                <label class="styled-label"><%= t(".urban_planning_act_type_4") %></label>
              </div>

              <div class="checkboxed">
                <input type="checkbox" disabled />
                <label class="styled-label"><%= t(".urban_planning_act_type_5") %></label>
              </div>
            </div>

          </div>
        </div>

        <div class="form-section">
          <button type="button" class="form-section__trigger" aria-expanded="false" data-toggle="general_plan_request_form_section_4">
            <%= image_pack_tag "media/images/chevron-down-thick.svg", alt: "", class: 'form-section__trigger-icon' %>

            <div>
              <h3><%= t(".section_4") %></h3>

              <span class="action">
                <span expand><%= t(".expand") %></span>
                <span collapse><%= t(".collapse") %></span>
              </span>
            </div>
          </button>
          
          <div id="general_plan_request_form_section_4"  data-toggler="form-section__content--visible" class="form-section__content form-section__content--visible">
            <div class="form-description">
              <%= t(".section_4_description").html_safe %>
            </div>

            <%= form.label :submitter_data_role, t('activemodel.attributes.general_plan_request.submitter_data_role').html_safe %>
            <div class="radio-wrapper">
              <div>
                <input type="radio" id="submitter_role_person" name="general_plan_request[submitter_data_role]" value="0" <%= "checked" unless @form.submitter_data_role == Decidim::GeneralPlanRequests::GeneralPlanRequest::ORGANIZATION %>>
                <label for="submitter_role_person"><%= t(".submitter_role_person") %></label>
              </div>

              <div>
                <input type="radio" id="submitter_role_organization" name="general_plan_request[submitter_data_role]" value="1" <%= "checked" if @form.submitter_data_role == Decidim::GeneralPlanRequests::GeneralPlanRequest::ORGANIZATION %>>
                <label for="submitter_role_organization"><%= t(".submitter_role_organization") %></label>
              </div>
            </div>

            <div class="submitter-form narrow-part person-form">
              <div class="narrow-part__fields">
                <div class="field">
                  <%= form.text_field :submitter_data_first_name,
                                      required: true,
                                      autocomplete: "given-name",
                                      data: { "disable-character-counter": true },
                                      label: t('activemodel.attributes.general_plan_request.submitter_data_first_name')+"*" %>
                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>

                <div class="field">
                  <%= form.text_field :submitter_data_last_name,
                                      required: true,
                                      autocomplete: "family-name",
                                      data: { "disable-character-counter": true },
                                      label: t('activemodel.attributes.general_plan_request.submitter_data_last_name')+"*" %>
                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>
              </div>
            </div>

            <div class="submitter-form narrow-part organization-form hidden">
              <%= form.text_field :submitter_data_org_name,
                                  autocomplete: "organization",
                                  data: { "disable-character-counter": true },
                                  label: t('activemodel.attributes.general_plan_request.submitter_data_org_name')+"*" %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>

            <div class="narrow-part">
              <%= form.text_field :submitter_data_country,
                                  required: true,
                                  autocomplete: "country",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>
            
            <div class="narrow-part">
              <%= form.text_field :submitter_data_voivodeship,
                                  required: true,
                                  autocomplete: "voivodeship",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>     

            <div class="narrow-part">
              <%= form.text_field :submitter_data_county,
                                  required: true,
                                  autocomplete: "county",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>     
            
            <div class="narrow-part">
              <%= form.text_field :submitter_data_community,
                                  required: true,
                                  autocomplete: "community",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>

            <div class="narrow-part">
              <%= form.text_field :submitter_data_street,
                                  required: true,
                                  autocomplete: "street-address",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>

            <div class="narrow-part">
              <div class="narrow-part__fields">
                <div class="field">
                  <%= form.text_field :submitter_data_street_number,
                                      required: true,
                                      autocomplete: "street-address",
                                      data: { "disable-character-counter": true } %>
                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>

                <div class="field">
                  <%= form.text_field :submitter_data_flat_number,
                                      data: { "disable-character-counter": true } %>
                </div>
              </div>

              <div class="narrow-part__fields">
                <div class="field">
                  <%= form.text_field :submitter_data_zip_code,
                                      required: true,
                                      autocomplete: "postal-code",
                                      data: { "disable-character-counter": true } %>

                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>

                <div class="field">
                  <%= form.text_field :submitter_data_city,
                                      required: true,
                                      autocomplete: "address-level2",
                                      data: { "disable-character-counter": true } %>
                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>
              </div>
            </div>

            <div class="narrow-part">
              <%= form.email_field :submitter_data_email,
                                  value: current_user.present? ? current_user.email : nil,
                                  autocomplete: "email",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.invalid") %></span>
            </div>

            <div class="narrow-part">
              <%= form.text_field :submitter_data_phone_number,
                                  autocomplete: "phone",
                                  data: { "disable-character-counter": true } %>
            </div>

            <div class="narrow-part">
              <%= form.text_field :submitter_data_epuap_delivery_address,
                                  data: { "disable-character-counter": true } %>

              <div class="form-description">
                <%= t(".epuap_delivery_address_description") %>
              </div>
            </div>

            <div class=""> 
              <%= form.label :perpetual_owner_of_the_property,
                            t('activemodel.attributes.general_plan_request.perpetual_owner_of_the_property')+"*",
                            for: "general_plan_request_perpetual_owner_of_the_property_true general_plan_request_perpetual_owner_of_the_property_false" %>

              <div class="radio-wrapper">
                <%= form.radio_button :perpetual_owner_of_the_property, true, required: true, label: t(".option_yes") %>
                <%= form.radio_button :perpetual_owner_of_the_property, false, required: true, label: t(".option_no") %>
              </div>
            </div>
          </div>
        </div>

        <div class="form-section">
          <button type="button" class="form-section__trigger" aria-expanded="false" data-toggle="general_plan_request_form_section_5">
            <%= image_pack_tag "media/images/chevron-down-thick.svg", alt: "", class: 'form-section__trigger-icon' %>

            <div>
              <h3><%= t(".section_5") %></h3>

              <span class="action">
                <span expand><%= t(".expand") %></span>
                <span collapse><%= t(".collapse") %></span>
              </span>
            </div>
          </button>
          
          <div id="general_plan_request_form_section_5"  data-toggler="form-section__content--visible" class="form-section__content">
            <div class="form-description">
              <%= t(".section_5_description").html_safe %>
            </div> 
            
            <div class="narrow-part">
              <%= form.text_field :mailing_address_data_country,
                                  autocomplete: "country",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>     

            <div class="narrow-part">
              <%= form.text_field :mailing_address_data_voivodeship,
                                  autocomplete: "voivodeship",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>     

            <div class="narrow-part">
              <%= form.text_field :mailing_address_data_county,
                                  autocomplete: "county",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>     
            
            <div class="narrow-part">
              <%= form.text_field :mailing_address_data_community,
                                  autocomplete: "community",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>

            <div class="narrow-part">
              <%= form.text_field :mailing_address_data_street,
                                  autocomplete: "street-address",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>

            <div class="narrow-part">
              <div class="narrow-part__fields">
                <div class="field">
                  <%= form.text_field :mailing_address_data_street_number,
                                      autocomplete: "street-address",
                                      data: { "disable-character-counter": true } %>
                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>

                <div class="field">
                  <%= form.text_field :mailing_address_data_flat_number,
                                      data: { "disable-character-counter": true } %>
                </div>
              </div>

              <div class="narrow-part__fields">
                <div class="field">
                  <%= form.text_field :mailing_address_data_zip_code,
                                      autocomplete: "postal-code",
                                      data: { "disable-character-counter": true } %>
                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>

                <div class="field">
                  <%= form.text_field :mailing_address_data_city,
                                      autocomplete: "address-level2",
                                      data: { "disable-character-counter": true } %>
                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="form-section">
          <button type="button" class="form-section__trigger" aria-expanded="false" data-toggle="general_plan_request_form_section_6">
            <%= image_pack_tag "media/images/chevron-down-thick.svg", alt: "", class: 'form-section__trigger-icon' %>

            <div>
              <h3><%= t(".section_6") %></h3>

              <span class="action">
                <span expand><%= t(".expand") %></span>
                <span collapse><%= t(".collapse") %></span>
              </span>
            </div>
          </button>
          
          <div id="general_plan_request_form_section_6"  data-toggler="form-section__content--visible" class="form-section__content">
            <div class="form-description">
              <%= t(".section_6_description").html_safe %>
            </div>

            <div class="radio-wrapper">          
              <%= form.radio_button :attorney_data_role, 0, label: t(".attorney_role_all") %>
              <%= form.radio_button :attorney_data_role, 1, label: t(".attorney_role_delivery") %>  
            </div>

            <div class="submitter-form narrow-part">
              <div class="narrow-part__fields">
                <div class="field">
                  <%= form.text_field :attorney_data_first_name,
                                      autocomplete: "given-name",
                                      data: { "disable-character-counter": true } %>
                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>

                <div class="field">
                  <%= form.text_field :attorney_data_last_name,
                                      autocomplete: "family-name",
                                      data: { "disable-character-counter": true } %>
                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>
              </div>
            </div>

            <div class="narrow-part">
              <%= form.text_field :attorney_data_country,
                                  autocomplete: "country",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>
            
            <div class="narrow-part">
              <%= form.text_field :attorney_data_voivodeship,
                                  autocomplete: "voivodeship",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>     
            
            <div class="narrow-part">
              <%= form.text_field :attorney_data_county,
                                  autocomplete: "county",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>    

            <div class="narrow-part">
              <%= form.text_field :attorney_data_community,
                                  autocomplete: "community",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>

            <div class="narrow-part">
              <%= form.text_field :attorney_data_street,
                                  autocomplete: "street-address",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>

            <div class="narrow-part">
              <div class="narrow-part__fields">
                <div class="field">
                  <%= form.text_field :attorney_data_street_number,
                                      autocomplete: "street-address",
                                      data: { "disable-character-counter": true } %>
                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>

                <div class="field">
                  <%= form.text_field :attorney_data_flat_number,
                                      data: { "disable-character-counter": true } %>
                </div>
              </div>

              <div class="narrow-part__fields">
                <div class="field">
                  <%= form.text_field :attorney_data_zip_code,
                                      autocomplete: "postal-code",
                                      data: { "disable-character-counter": true } %>
                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>

                <div class="field">
                  <%= form.text_field :attorney_data_city,
                                      autocomplete: "address-level2",
                                      data: { "disable-character-counter": true } %>
                  <span class="form-error"><%= t("errors.messages.required") %></span>
                </div>
              </div>
            </div>

            <div class="narrow-part">
              <%= form.email_field :attorney_data_email,
                                  autocomplete: "email",
                                  data: { "disable-character-counter": true } %>
              <span class="form-error"><%= t("errors.messages.invalid") %></span>
            </div>

            <div class="narrow-part">
              <%= form.text_field :attorney_data_phone_number,
                                  autocomplete: "phone",
                                  data: { "disable-character-counter": true } %>
            </div>

            <div class="narrow-part">
              <%= form.text_field :attorney_data_epuap_delivery_address,
                                  data: { "disable-character-counter": true } %>

              <div class="form-description">
                <%= t(".epuap_delivery_address_description") %>
              </div>
            </div> 
          </div>
        </div>

        <div class="form-section">
          <button type="button" class="form-section__trigger" aria-expanded="false" data-toggle="general_plan_request_form_section_7">
            <%= image_pack_tag "media/images/chevron-down-thick.svg", alt: "", class: 'form-section__trigger-icon' %>

            <div>
              <h3><%= t(".section_7") %></h3>

              <span class="action">
                <span expand><%= t(".expand") %></span>
                <span collapse><%= t(".collapse") %></span>
              </span>
            </div>
          </button>
          
          <div id="general_plan_request_form_section_7"  data-toggler="form-section__content--visible" class="form-section__content form-section__content--visible">
            <div class="form-description">
              <%= @form.request_body_description_with_hyperlinks %>
            </div>

            <div class="narrow-part">
              <%= form.text_area(
                    :request_body,
                    id: 'general_plan_request_request_body',
                    rows: 8,
                    maxlength: 1000,
                    required: true, 
                    data: { remaining_characters: "#request_body-remaining-characters" },
                    aria: { describedby: "request_body-remaining-characters" }
                  ) %>
              <span class="form-error"><%= t("errors.messages.required") %></span>
            </div>

            <div class="form-section">
              <button type="button" class="form-section__trigger form-section__trigger--small" aria-expanded="false" data-toggle="request_body_content_details">
                <%= image_pack_tag "media/images/chevron-down-thick.svg", alt: "", class: 'form-section__trigger-icon form-section__trigger-icon--small' %>

                <div>
                  <label><%= t('activemodel.attributes.general_plan_request.request_body_content_details') %></label>

                  <span class="action">
                    <span expand><%= t(".expand") %></span>
                    <span collapse><%= t(".collapse") %></span>
                  </span>
                </div>
              </button>
            

              <div data-toggler="form-section__content--visible" class="form-section__content multiple-hash-input" id="request_body_content_details">
                <%= form.hidden_field :request_body_content_details %>
      
                <ol class="multiple-hash-input__items"></ol>

                <button type="button" class="multiple-hash-input__add-button multiple-hash-input__add-button-js">
                  <%= image_pack_tag "media/images/plus.svg", alt: "" %>

                  <span>
                    <%= t(".add_item") %>
                  </span>
                </button>
              </div>
            </div>

            <div class="form-section">
              <button type="button" class="form-section__trigger form-section__trigger--small" aria-expanded="false" data-toggle="details_land_parcels_with_parameters">
                <%= image_pack_tag "media/images/chevron-down-thick.svg", alt: "", class: 'form-section__trigger-icon form-section__trigger-icon--small' %>

                <div>
                  <label><%= t('activemodel.attributes.general_plan_request.details_land_parcels_with_parameters') %></label>

                  <span class="action">
                    <span expand><%= t(".expand") %></span>
                    <span collapse><%= t(".collapse") %></span>
                  </span>
                </div>
              </button>
            

              <div data-toggler="form-section__content--visible" class="form-section__content multiple-hash-input" id="details_land_parcels_with_parameters">
                <%= form.hidden_field :details_land_parcels_with_parameters %>
      
                <ol class="multiple-hash-input__items"></ol>

                <button type="button" class="multiple-hash-input__add-button multiple-hash-input__add-button-js">
                  <%= image_pack_tag "media/images/plus.svg", alt: "" %>

                  <span>
                    <%= t(".add_item") %>
                  </span>
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="form-section">
          <button type="button" class="form-section__trigger" aria-expanded="false" data-toggle="general_plan_request_form_section_8">
            <%= image_pack_tag "media/images/chevron-down-thick.svg", alt: "", class: 'form-section__trigger-icon' %>

            <div>
              <h3><%= t(".section_8") %></h3>

              <span class="action">
                <span expand><%= t(".expand") %></span>
                <span collapse><%= t(".collapse") %></span>
              </span>
            </div>
          </button>
          
          <div id="general_plan_request_form_section_8"  data-toggler="form-section__content--visible" class="form-section__content form-section__content--visible">

            <div class="radio-wrapper !mb-2">
              <%= form.radio_button :declaration_remote_correspondence, true, required: true, label: t(".declaration_remote_correspondence_true") %>
