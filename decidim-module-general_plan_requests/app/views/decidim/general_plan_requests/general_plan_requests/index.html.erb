    renderContentDetails();
    initContentDetailsChangeEvents();

    function initContentDetailsChangeEvents() {
      $(
        "#request_body_content_details input, #request_body_content_details textarea"
      ).on("change", function (event) {
        var contentDetails = JSON.parse(
          $("#general_plan_request_request_body_content_details").val() ||
            `[{"index": "0", "name": "Plan ogólny gminy"}]`
        );
        var index = parseInt($(this).data("index"));
        var key = $(this).data("key");
        var value = event.target.value;

        contentDetails[index][key] = value;
        $("#general_plan_request_request_body_content_details").val(
          JSON.stringify(contentDetails)
        );
      });

      $(
        "#request_body_content_details .multiple-hash-input__delete-button-js"
      ).on("click", function () {
        var index = $(this).data("index");
        var contentDetails = JSON.parse(
          $("#general_plan_request_request_body_content_details").val() ||
            `[{"index": "0", "name": "Plan ogólny gminy"}]`
        );
        contentDetails = contentDetails.filter(function (item) {
          return item.index != index;
        });
        $("#general_plan_request_request_body_content_details").val(
          JSON.stringify(contentDetails)
        );

        renderContentDetails();
        initContentDetailsChangeEvents();
      });

      $("#request_body_content_details .multiple-hash-input__items > li").each(
        function () {
          const index = this.id.split("_").pop();
          const regex = new RegExp(
            `request_body_content_details_(parcel_id|body|is_record_area_included)_item_${index}`
          );

          $("input:not([type=radio]), textarea")
            .filter(function () {
              return this.id.match(regex);
            })
            .on("change", function (event) {
              const inputs = $("input:not([type=radio]), textarea").filter(
                function () {
                  return this.id.match(regex);
                }
              );
              const radioInputs = $("input[type=radio]").filter(function () {
                return this.id.match(regex);
              });

              if (event.target.value.length > 0) {
                inputs.attr("required", "required");
                radioInputs.attr("required", "required");
                inputs.each(function () {
                  const label = $("label[for='" + this.id + "']");
                  label.find("span.asterisk").remove();
                  $(label).append('<span class="asterisk">*</span>');
                });
              } else {
                const emptyInputs = $("input:not([type=radio]), textarea").filter(
                  function () {
                    return this.id.match(regex) && this.value === "";
                  }
                );

                if (emptyInputs.length === inputs.length) {
                  inputs.removeAttr("required");
                  radioInputs.removeAttr("required");
                  inputs.each(function () {
                    $("#new_general_plan_request_").foundation(
                      "validateInput",
                      $(this)
                    );

                    const label = $("label[for='" + this.id + "']");
                    label.find("span.asterisk").remove();
                  });
                }
              }
            });
        }
      );
    }

    $("#request_body_content_details .multiple-hash-input__add-button-js").on(
      "click",
      function () {
        var contentDetails = JSON.parse(
          $("#general_plan_request_request_body_content_details").val() ||
            `[{"index": "0", "name": "Plan ogólny gminy"}]`
        );
        contentDetails.push({
          index: contentDetails.length,
          name: "Plan ogólny gminy",
        });
        $("#general_plan_request_request_body_content_details").val(
          JSON.stringify(contentDetails)
        );

        renderContentDetails(true);
        initContentDetailsChangeEvents();
      }
    );

