          `details_land_parcels_with_parameters_(parcel_id|area_class_name|is_record_area_included|max_percent_area|max_height_building|min_percent_bio)_item_${index}`
        );

        $("input:not([type=radio]), textarea")
          .filter(function () {
            return this.id.match(regex);
          })
          .on("change", function (event) {
            const inputs = $("input:not([type=radio]), textarea").filter(
              function () {
                return this.id.match(regex);
              }
            );
            const radioInputs = $("input[type=radio]").filter(function () {
              return this.id.match(regex);
            });

            if (event.target.value.length > 0) {
              inputs.attr("required", "required");
              radioInputs.attr("required", "required");
              inputs.each(function () {
                const label = $("label[for='" + this.id + "']");
                label.find("span.asterisk").remove();
                $(label).append('<span class="asterisk">*</span>');
              });
            } else {
              const emptyInputs = $("input:not([type=radio]), textarea").filter(
                function () {
                  return this.id.match(regex) && this.value === "";
                }
              );

              if (emptyInputs.length === inputs.length) {
                inputs.removeAttr("required");
                radioInputs.removeAttr("required");
                inputs.each(function () {
                  $("#new_general_plan_request_").foundation(
                    "validateInput",
                    $(this)
                  );

                  const label = $("label[for='" + this.id + "']");
                  label.find("span.asterisk").remove();
                });
              }
            }
          });
      });
    }

    $(
      "#details_land_parcels_with_parameters .multiple-hash-input__add-button-js"
    ).on("click", function () {
      var landParcels = JSON.parse(
        $("#general_plan_request_details_land_parcels_with_parameters").val() ||
          `[{"index": "0", "name": "Plan ogólny m.st. Warszawy"}]`
      );
      landParcels.push({
        index: landParcels.length,
        name: "Plan ogólny m.st. Warszawy",
      });
      $("#general_plan_request_details_land_parcels_with_parameters").val(
        JSON.stringify(landParcels)
      );

      renderLandParcels(true);
      initLandParcelsChangeEvents();
    });


    $("input[type=file]#general_plan_request_files")
      .not(".MultiFile-applied")
      .MultiFile({
        max: 2,
        STRING: {
          remove: "usuń",
          denied: "Ten format pliku $ext jest niedozwolony.",
          file: "$file",
          selected: "Wybrany plik: $file",
          duplicate: "Ten plik już został wybrany:\n$file",
          toomuch: "Łączny rozmiar plików przekracza limit ($size)",
          toomany: "Niedozwolona liczba plików (maks: $max)",
          toobig: "$file ma za duży rozmiar (maks: $size)",
        },
        afterFileAppend: function (element, value, master_element) {
          master_element.files.forEach(function (file, index) {
            if (index === 0 && master_element.files.length > 1) {
              if (
                $(`#general_plan_request_files_list > div:eq(${index})`).hasClass(
                  "MultiFile-label--added-inputs"
                )
              ) {
                return;
              } else {
                $(`#general_plan_request_files_list > div:eq(${index})`).append(
                  `
                    <div>
                      <label for="files_filename_one" ><%= t('activemodel.attributes.general_plan_request.files_filename_one') %> 1</label>
                      <input id="files_filename_one" type="text" name="general_plan_request[files_filename_one]" required /> 
                      <span class="form-error"><%= t("errors.messages.required") %></span>
                    </div>
                    <div>
                      <label for="files_filename_two" ><%= t('activemodel.attributes.general_plan_request.files_filename_two') %> 2</label>
                      <input id="files_filename_two" type="text" name="general_plan_request[files_filename_two]" required /> 
                      <span class="form-error"><%= t("errors.messages.required") %></span>
                    </div>
                  `
                );
                $(`#general_plan_request_files_list > div:eq(${index})`).addClass(
                  "MultiFile-label--added-inputs"
                );
              }
            }

            if (
              !$(`#general_plan_request_files_list > div:eq(${index})`).hasClass(
                "MultiFile-label--added-inputs"
              )
            ) {
              $(`#general_plan_request_files_list > div:eq(${index})`).append(
                `
                  <div>
                    <label for="files_filename_${
                      index === 0 ? "one" : "two"
                    }" ><%= t('activemodel.attributes.general_plan_request.files_filename_one') %></label>
                    <input id="files_filename_${
                      index === 0 ? "one" : "two"
                    }" type="text" name="general_plan_request[files_filename_${
                  index === 0 ? "one" : "two"
                }]" required /> 
                    <span class="form-error"><%= t("errors.messages.required") %></span>
                  </div>
                `
              );

              $(`#general_plan_request_files_list > div:eq(${index})`).addClass(
                "MultiFile-label--added-inputs"
              );
            }

            Foundation.reInit("abide");
          });

          if (master_element.files.length >= 2) {
            $(this).parent().find(".attachment-button-js").hide();
          }
        },
        afterFileRemove: function (element, value, master_element) {
          if (master_element.files.length < 2) {
            $(this).parent().find(".attachment-button-js").show();
          }
        },
      });
  <% end %>
<% end %>